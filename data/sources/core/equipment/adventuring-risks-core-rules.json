        "category": "Poison",
        "status": "Active",
        "save": "Constitution Saving Throw",
        "effect": "Apply the poison's Blight effect if the target fails the save.",
        "riskNotes": "<p>One dose affects a single target and remains on the object until a hit, touch, wipe-off, or DM-adjudicated degradation.</p>"
      },
      "flags": {
        "anime5e": {
          "sourceId": "core.adventuring-risk.poison-contact",
