        "category": "Deprivation",
        "status": "Active",
        "interval": "Every 8 hours",
        "damage": "1 incurable Hit Point loss",
        "effect": "Cannot recover this HP loss until food deprivation ends.",
        "riskNotes": "<p>Use the actor sheet Deprivation controls or this risk row to apply each elapsed interval.</p>"
      },
      "flags": {
