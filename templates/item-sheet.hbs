<form class="anime5e-form" autocomplete="off">
  <header class="sheet-header">
    <div class="portrait">
      <img src="{{item.img}}" alt="{{item.name}}">
      <label>
        {{localize "ANIME5E.Labels.Source"}}
        <input type="text" name="img" value="{{item.img}}" {{#unless editable}}disabled{{/unless}}>
      </label>
    </div>
    <div class="identity">
      <label>
        {{localize "ANIME5E.Labels.Name"}}
        <input type="text" name="name" value="{{item.name}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <div class="inline-fields">
        <label>
          {{localize "ANIME5E.Labels.Type"}}
          <input type="text" value="{{item.type}}" disabled>
        </label>
        <label>
          {{localize "ANIME5E.Labels.Rank"}}
          <input type="number" name="system.rank" value="{{system.rank}}" min="0" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          {{localize "ANIME5E.Labels.Cost"}}
          <input type="number" name="system.cost" value="{{system.cost}}" min="0" {{#unless editable}}disabled{{/unless}}>
        </label>
      </div>
    </div>
  </header>

  <section class="panel item-actions-panel">
    <h2>Actions</h2>
    <div class="item-action-buttons">
      {{#if itemActions.canUse}}
        <button type="button" class="roll-action" data-action="use-item"><i class="fas fa-comment"></i> Use</button>
      {{/if}}
      {{#if itemActions.canRoll}}
        <button type="button" class="roll-action" data-action="roll-item"><i class="fas fa-dice-d20"></i> Roll</button>
      {{/if}}
      {{#if itemActions.canAttack}}
        <button type="button" class="roll-action" data-action="roll-item-attack"><i class="fas fa-crosshairs"></i> Attack</button>
      {{/if}}
      {{#if itemActions.canDamage}}
        <button type="button" class="roll-action" data-action="roll-item-damage"><i class="fas fa-bolt"></i> Damage</button>
      {{/if}}
    </div>
  </section>

  <section class="panel">
    <h2>{{localize "ANIME5E.Labels.Description"}}</h2>
    <textarea name="system.description" {{#unless editable}}disabled{{/unless}}>{{system.description}}</textarea>
  </section>

  {{#if detailFields}}
    <section class="panel">
      <h2>{{localize "ANIME5E.Labels.Details"}}</h2>
      <div class="detail-fields">
        {{#each detailFields as |field|}}
          <label class="{{#if field.isMultiline}}wide{{/if}}">
            {{field.label}}
            {{#if field.isBoolean}}
              <span class="checkbox-field">
                <input type="hidden" name="{{field.name}}" value="false">
                <input type="checkbox" name="{{field.name}}" value="true" {{#if field.value}}checked{{/if}} {{#unless ../editable}}disabled{{/unless}}>
              </span>
            {{else}}
              {{#if field.isMultiline}}
                <textarea name="{{field.name}}" {{#unless ../editable}}disabled{{/unless}}>{{field.displayValue}}</textarea>
              {{else}}
                {{#if field.isNumber}}
                  <input type="number" name="{{field.name}}" value="{{field.displayValue}}" {{#unless ../editable}}disabled{{/unless}}>
                {{else}}
                  <input type="text" name="{{field.name}}" value="{{field.displayValue}}" {{#unless ../editable}}disabled{{/unless}}>
                {{/if}}
              {{/if}}
            {{/if}}
          </label>
        {{/each}}
      </div>
    </section>
  {{/if}}

  {{#if constructionPlaceholder}}
    <section class="panel construction-panel">
      <h2>Item Construction</h2>
      <p>{{constructionPlaceholder.message}}</p>
    </section>
  {{/if}}

  <section class="panel">
    <h2>{{localize "ANIME5E.Labels.Source"}}</h2>
    <div class="inline-fields">
      <label>
        {{localize "ANIME5E.Labels.Source"}}
        <input type="text" name="system.source" value="{{system.source}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        {{localize "ANIME5E.Labels.SourceId"}}
        <input type="text" name="system.sourceId" value="{{system.sourceId}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        {{localize "ANIME5E.Labels.SourcePage"}}
        <input type="number" name="system.sourcePage" value="{{system.sourcePage}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        {{localize "ANIME5E.Labels.ImportId"}}
        <input type="text" name="system.importId" value="{{system.importId}}" {{#unless editable}}disabled{{/unless}}>
      </label>
    </div>
  </section>

  {{#if editable}}
    <footer class="sheet-footer">
      <button type="submit">{{localize "ANIME5E.Labels.Save"}}</button>
    </footer>
  {{/if}}
</form>
