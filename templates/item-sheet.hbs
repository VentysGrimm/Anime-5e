<form class="anime5e-form" autocomplete="off">
  <header class="sheet-header">
    <div class="portrait">
      <img src="{{item.img}}" alt="{{item.name}}">
      <label>
        {{localize "ANIME5E.Labels.Source"}}
        <input type="text" name="img" value="{{item.img}}" {{#unless editable}}disabled{{/unless}}>
      </label>
    </div>
    <div class="identity">
      <label>
        {{localize "ANIME5E.Labels.Name"}}
        <input type="text" name="name" value="{{item.name}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <div class="inline-fields">
        <label>
          {{localize "ANIME5E.Labels.Type"}}
          <input type="text" value="{{item.type}}" disabled>
        </label>
        <label>
          {{localize "ANIME5E.Labels.Rank"}}
          <input type="number" name="system.rank" value="{{system.rank}}" min="0" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          {{localize "ANIME5E.Labels.Cost"}}
          <input type="number" name="system.cost" value="{{system.cost}}" min="0" {{#unless editable}}disabled{{/unless}}>
        </label>
      </div>
    </div>
  </header>

  <section class="panel item-actions-panel">
    <h2>Actions</h2>
    <div class="item-action-buttons">
      {{#if itemActions.canUse}}
        <button type="button" class="roll-action" data-action="use-item"><i class="fas fa-comment"></i> Use</button>
      {{/if}}
      {{#if itemActions.canRoll}}
        <button type="button" class="roll-action" data-action="roll-item"><i class="fas fa-dice-d20"></i> Roll</button>
      {{/if}}
      {{#if itemActions.canAttack}}
        <button type="button" class="roll-action" data-action="roll-item-attack"><i class="fas fa-crosshairs"></i> Attack</button>
      {{/if}}
      {{#if itemActions.canDamage}}
        <button type="button" class="roll-action" data-action="roll-item-damage"><i class="fas fa-bolt"></i> Damage</button>
      {{/if}}
    </div>
  </section>

  <section class="panel">
    <h2>{{localize "ANIME5E.Labels.Description"}}</h2>
    <textarea name="system.description" {{#unless editable}}disabled{{/unless}}>{{system.description}}</textarea>
  </section>

  {{#if detailFields}}
    <section class="panel">
      <h2>{{localize "ANIME5E.Labels.Details"}}</h2>
      <div class="detail-fields">
        {{#each detailFields as |field|}}
          <label class="{{#if field.isMultiline}}wide{{/if}}">
            {{field.label}}
            {{#if field.isBoolean}}
              <span class="checkbox-field">
                <input type="hidden" name="{{field.name}}" value="false">
                <input type="checkbox" name="{{field.name}}" value="true" {{#if field.value}}checked{{/if}} {{#unless ../editable}}disabled{{/unless}}>
              </span>
            {{else}}
              {{#if field.isMultiline}}
                <textarea name="{{field.name}}" {{#unless ../editable}}disabled{{/unless}}>{{field.displayValue}}</textarea>
              {{else}}
                {{#if field.isNumber}}
                  <input type="number" name="{{field.name}}" value="{{field.displayValue}}" {{#unless ../editable}}disabled{{/unless}}>
                {{else}}
                  <input type="text" name="{{field.name}}" value="{{field.displayValue}}" {{#unless ../editable}}disabled{{/unless}}>
                {{/if}}
              {{/if}}
            {{/if}}
          </label>
        {{/each}}
      </div>
    </section>
  {{/if}}

  {{#if attributeModifiers}}
    <section class="panel attribute-modifier-panel">
      <h2>{{attributeModifiers.heading}}</h2>
      <div class="attribute-modifier-summary">
        {{#each attributeModifiers.summary as |summary|}}
          <span>{{summary.label}} <strong>{{summary.value}}</strong></span>
        {{/each}}
      </div>
      {{#each attributeModifiers.warnings as |warning|}}
        <p class="sheet-warning">{{warning}}</p>
      {{/each}}

      {{#each attributeModifiers.groups as |group|}}
        <div class="attribute-modifier-group">
          <h3>{{group.label}}</h3>
          <div class="attribute-modifier-add">
            <input type="text" data-modifier-input="{{group.type}}" {{#unless ../editable}}disabled{{/unless}}>
            <button type="button" data-action="add-attribute-modifier" data-modifier-type="{{group.type}}" {{#unless ../editable}}disabled{{/unless}}>
              <i class="fas fa-plus"></i>
              <span>Add</span>
            </button>
          </div>

          {{#if group.entries}}
            <div class="attribute-modifier-list">
              <div class="table-header">Name</div>
              <div class="table-header">Reference</div>
              <div class="table-header">Each</div>
              <div class="table-header">Assignments</div>
              <div class="table-header">Total</div>
              <div class="table-header">Notes</div>
              <div class="table-header">Remove</div>
              {{#each group.entries as |entry|}}
                <span>{{entry.name}}</span>
                <span>{{entry.referenceLabel}}</span>
                <span>{{entry.pointModifierLabel}}</span>
                <span>
                  <input type="number" name="system.{{../field}}.{{entry.index}}.assignmentCount" value="{{entry.assignmentCount}}" min="0" {{#unless ../../editable}}disabled{{/unless}}>
                </span>
                <span>{{entry.totalLabel}}</span>
                <span>{{entry.notes}}</span>
                <span>
                  <button type="button" class="icon-button" data-action="remove-attribute-modifier" data-modifier-type="{{../type}}" data-index="{{entry.index}}" title="Remove {{entry.name}}" {{#unless ../../editable}}disabled{{/unless}}>
                    <i class="fas fa-trash"></i>
                  </button>
                </span>
              {{/each}}
            </div>
          {{/if}}
        </div>
      {{/each}}
    </section>
  {{/if}}

  {{#if speciesTraits}}
    <section class="panel species-trait-panel">
      <h2>Species Traits</h2>
      <div class="species-trait-summary">
        {{#each speciesTraits.summary as |summary|}}
          <span>{{summary.label}} <strong>{{summary.value}}</strong></span>
        {{/each}}
      </div>

      {{#if speciesTraits.abilityBonuses}}
        <div class="species-trait-section">
          <h3>Ability Bonuses</h3>
          <div class="species-trait-grid ability-bonus-grid">
            <div class="table-header">Ability</div>
            <div class="table-header">Bonus</div>
            <div class="table-header">Points</div>
            <div class="table-header">Notes</div>
            {{#each speciesTraits.abilityBonuses as |bonus|}}
              <span>{{bonus.ability}}</span>
              <span>{{bonus.modifierLabel}}</span>
              <span>{{bonus.pointsLabel}}</span>
              <span>{{bonus.notes}}</span>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{#if speciesTraits.attributes}}
        <div class="species-trait-section">
          <h3>Attributes</h3>
          <div class="species-trait-grid trait-entry-grid">
            <div class="table-header">Trait</div>
            <div class="table-header">Rank</div>
            <div class="table-header">Points</div>
            <div class="table-header">Detail</div>
            <div class="table-header">Notes</div>
            {{#each speciesTraits.attributes as |trait|}}
              <span>{{trait.name}}</span>
              <span>{{trait.rankLabel}}</span>
              <span>{{trait.pointsLabel}}</span>
              <span>{{trait.detail}}</span>
              <span>{{trait.notes}}</span>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{#if speciesTraits.defects}}
        <div class="species-trait-section">
          <h3>Defects</h3>
          <div class="species-trait-grid trait-entry-grid">
            <div class="table-header">Trait</div>
            <div class="table-header">Rank</div>
            <div class="table-header">Points</div>
            <div class="table-header">Detail</div>
            <div class="table-header">Notes</div>
            {{#each speciesTraits.defects as |trait|}}
              <span>{{trait.name}}</span>
              <span>{{trait.rankLabel}}</span>
              <span>{{trait.pointsLabel}}</span>
              <span>{{trait.detail}}</span>
              <span>{{trait.notes}}</span>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{#if speciesTraits.languages}}
        <div class="species-trait-section">
          <h3>Languages</h3>
          <div class="species-trait-tags">
            {{#each speciesTraits.languages as |language|}}
              <span>{{language}}</span>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{#if speciesTraits.movement}}
        <div class="species-trait-section">
          <h3>Movement</h3>
          <div class="species-trait-grid movement-grid">
            <div class="table-header">Mode</div>
            <div class="table-header">Speed</div>
            <div class="table-header">Notes</div>
            {{#each speciesTraits.movement as |movement|}}
              <span>{{movement.mode}}</span>
              <span>{{movement.speed}}</span>
              <span>{{movement.notes}}</span>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{#if speciesTraits.traitNotes}}
        <p class="species-trait-notes">{{speciesTraits.traitNotes}}</p>
      {{/if}}
    </section>
  {{/if}}

  {{#if classProgression}}
    <section class="panel class-progression-panel">
      <h2>Class Progression</h2>
      <div class="class-progression-summary">
        {{#each classProgression.summary as |summary|}}
          <span>{{summary.label}} <strong>{{summary.value}}</strong></span>
        {{/each}}
      </div>
      <div class="class-progression-table">
        <div class="table-header">Level</div>
        <div class="table-header">Prof</div>
        <div class="table-header">Points</div>
        <div class="table-header">Benefits</div>
        <div class="table-header">Notes</div>
        {{#each classProgression.entries as |entry|}}
          <span>{{entry.levelLabel}}</span>
          <span>{{entry.proficiencyBonus}}</span>
          <span>{{entry.points}}</span>
          <span>{{entry.benefits}}</span>
          <span>{{entry.notes}}</span>
        {{/each}}
      </div>
    </section>
  {{/if}}

  {{#if constructionPlaceholder}}
    <section class="panel construction-panel">
      <h2>Item Construction</h2>
      <p>{{constructionPlaceholder.message}}</p>
      {{#if constructionPlaceholder.rows}}
        <div class="construction-summary">
          {{#each constructionPlaceholder.rows as |row|}}
            <span>{{row.label}} <strong>{{row.value}}</strong></span>
          {{/each}}
        </div>
      {{/if}}
    </section>
  {{/if}}

  <section class="panel">
    <h2>{{localize "ANIME5E.Labels.Source"}}</h2>
    <div class="inline-fields">
      <label>
        {{localize "ANIME5E.Labels.Source"}}
        <input type="text" name="system.source" value="{{system.source}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        {{localize "ANIME5E.Labels.SourceId"}}
        <input type="text" name="system.sourceId" value="{{system.sourceId}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        {{localize "ANIME5E.Labels.SourcePage"}}
        <input type="number" name="system.sourcePage" value="{{system.sourcePage}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        {{localize "ANIME5E.Labels.ImportId"}}
        <input type="text" name="system.importId" value="{{system.importId}}" {{#unless editable}}disabled{{/unless}}>
      </label>
    </div>
  </section>

  {{#if editable}}
    <footer class="sheet-footer">
      <button type="submit">{{localize "ANIME5E.Labels.Save"}}</button>
    </footer>
  {{/if}}
</form>
