<form class="anime5e-form basic-actor-form" autocomplete="off">
  <header class="sheet-header">
    <div class="portrait">
      <img src="{{actor.img}}" alt="{{actor.name}}">
      <label>
        Image
        <input type="text" name="img" value="{{actor.img}}" {{#unless editable}}disabled{{/unless}}>
      </label>
    </div>
    <div class="identity">
      <label>
        {{localize "ANIME5E.Labels.Name"}}
        <input type="text" name="name" value="{{actor.name}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <div class="inline-fields">
        <label>
          {{localize "ANIME5E.Labels.Type"}}
          <input type="text" value="{{actor.type}}" disabled>
        </label>
        <label>
          {{localize "ANIME5E.Labels.Level"}}
          <input type="number" name="system.level" value="{{system.level}}" min="1" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Challenge
          <input type="text" name="system.identity.challengeRating" value="{{system.identity.challengeRating}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          XP
          <input type="number" name="system.identity.experienceValue" value="{{system.identity.experienceValue}}" min="0" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Points
          <input type="number" name="system.identity.totalPoints" value="{{system.identity.totalPoints}}" min="0" {{#unless editable}}disabled{{/unless}}>
        </label>
      </div>
      <textarea name="system.identity.description" {{#unless editable}}disabled{{/unless}}>{{system.identity.description}}</textarea>
    </div>
  </header>

  {{#if creatureProfile.active}}
    <section class="panel creature-profile-panel">
      <h2>Creature Profile</h2>
      <div class="inline-fields">
        <label>
          Size / Type
          <input type="text" name="system.identity.speciesAndSize" value="{{system.identity.speciesAndSize}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Habitat
          <input type="text" name="system.identity.homelandHabitat" value="{{system.identity.homelandHabitat}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Communities
          <input type="text" name="system.identity.communities" value="{{system.identity.communities}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Alignment
          <input type="text" name="system.identity.alignment" value="{{system.identity.alignment}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Armour
          <input type="text" name="system.combat.armourNotes" value="{{system.combat.armourNotes}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Source
          <input type="text" name="system.source.book" value="{{system.source.book}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Page
          <input type="number" name="system.source.page" value="{{system.source.page}}" min="0" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Source Abbrev.
          <input type="text" name="system.source.abbreviation" value="{{system.source.abbreviation}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Source Module
          <input type="text" name="system.source.moduleId" value="{{system.source.moduleId}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Source Category
          <input type="text" name="system.source.category" value="{{system.source.category}}" {{#unless editable}}disabled{{/unless}}>
        </label>
      </div>
    </section>

    <section class="folio-grid two-column creature-summary-grid">
      <section class="panel creature-challenge-panel">
        <h2>Challenge Summary</h2>
        <div class="creature-summary-list">
          {{#each creatureProfile.challengeRows as |row|}}
            <span>{{row.label}}</span>
            <strong>{{row.value}}</strong>
          {{/each}}
        </div>
      </section>
      <section class="panel creature-point-panel">
        <h2>Point Summary</h2>
        <div class="creature-summary-list">
          {{#each creatureProfile.pointRows as |row|}}
            <span>{{row.label}}</span>
            <strong>{{row.value}}</strong>
          {{/each}}
        </div>
      </section>
      <section class="notes-box compact-notes">
        <h2>Defense Summary</h2>
        <textarea name="system.combat.defenseSummary" {{#unless editable}}disabled{{/unless}}>{{system.combat.defenseSummary}}</textarea>
      </section>
      <section class="notes-box compact-notes">
        <h2>Offense Summary</h2>
        <textarea name="system.combat.offenseSummary" {{#unless editable}}disabled{{/unless}}>{{system.combat.offenseSummary}}</textarea>
      </section>
    </section>
  {{/if}}

  {{#if transportProfile.active}}
    <section class="panel transport-profile-panel">
      <h2>{{transportProfile.actorType}} Profile</h2>
      <div class="inline-fields">
        <label>
          Pilot / Controller
          <input type="text" name="system.transport.pilot" value="{{system.transport.pilot}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Occupants
          <input type="text" name="system.transport.occupants" value="{{system.transport.occupants}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Capacity
          <input type="text" name="system.transport.capacity" value="{{system.transport.capacity}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Crew
          <input type="text" name="system.transport.crew" value="{{system.transport.crew}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Actor Build Points
          <input type="number" name="system.transport.actorBuildPoints" value="{{system.transport.actorBuildPoints}}" min="0" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Item Build Points
          <input type="number" name="system.transport.itemBuildPoints" value="{{system.transport.itemBuildPoints}}" min="0" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Linked Actor UUID
          <input type="text" name="system.transport.linkedActorUuid" value="{{system.transport.linkedActorUuid}}" {{#unless editable}}disabled{{/unless}}>
        </label>
        {{#if transportProfile.hasLinkedActor}}
          <button type="button" class="roll-action" data-action="open-linked-actor" data-linked-uuid="{{system.transport.linkedActorUuid}}"><i class="fas fa-external-link-alt"></i> Linked Actor</button>
        {{/if}}
      </div>
      <label class="full-width">
        Cargo / Notes
        <textarea name="system.transport.cargo" {{#unless editable}}disabled{{/unless}}>{{system.transport.cargo}}</textarea>
      </label>
    </section>
  {{/if}}

  <section class="panel basic-stat-panel">
    <h2>{{localize "ANIME5E.Labels.Abilities"}}</h2>
    <div class="basic-ability-grid">
      {{#each abilities as |ability|}}
        <label>
          <span>{{ability.label}}</span>
          <input type="number" name="system.abilities.{{ability.key}}.value" value="{{ability.data.value}}" {{#unless ../editable}}disabled{{/unless}}>
          <strong>{{ability.data.modifier}}</strong>
          <button type="button" class="icon-button roll-button" data-action="roll-ability" data-ability="{{ability.key}}" data-label="{{ability.label}} Check" title="Roll {{ability.label}}">
            <i class="fas fa-dice-d20"></i>
          </button>
        </label>
      {{/each}}
    </div>
  </section>

  <section class="panel save-roll-panel">
    <h2>Checks and Saves</h2>
    <section class="quick-roll-panel" aria-label="Quick Rolls">
      <h3>Quick Rolls</h3>
      <div class="quick-roll-controls">
        <label>
          Ability
          <select data-roll-input="ability">
            {{#each abilities as |ability|}}
              <option value="{{ability.key}}">{{ability.label}}</option>
            {{/each}}
          </select>
        </label>
        <label>
          Mode
          <select data-roll-input="mode">
            {{#each rollModes as |mode|}}
              <option value="{{mode.key}}">{{mode.label}}</option>
            {{/each}}
          </select>
        </label>
        <label>
          Roll
          <select data-roll-input="d20Mode">
            {{#each d20Modes as |mode|}}
              <option value="{{mode.key}}">{{mode.label}}</option>
            {{/each}}
          </select>
        </label>
        <label>
          DC
          <input type="number" data-roll-input="dc" value="0" min="0">
        </label>
        <label>
          Bonus
          <input type="number" data-roll-input="bonus" value="0">
        </label>
        <button type="button" class="roll-action" data-action="roll-quick"><i class="fas fa-dice-d20"></i> Roll</button>
        <button type="button" class="roll-action" data-action="roll-contest"><i class="fas fa-user-friends"></i> Contest</button>
        <button type="button" class="roll-action" data-action="open-roll-dialog"><i class="fas fa-window-restore"></i> Dialog</button>
      </div>
    </section>
    <div class="save-roll-controls">
      <label>
        Save Roll
        <select data-roll-input="saveD20Mode">
          {{#each d20Modes as |mode|}}
            <option value="{{mode.key}}">{{mode.label}}</option>
          {{/each}}
        </select>
      </label>
      <label class="checkbox-field">
        <input type="checkbox" data-roll-input="saveProficiency">
        Proficiency
      </label>
    </div>
    <div class="save-roll-buttons">
      {{#each abilities as |ability|}}
        <button type="button" data-action="roll-saving-throw" data-ability="{{ability.key}}" title="Roll {{ability.label}} Saving Throw"><i class="fas fa-dice-d20"></i><span>{{ability.label}}</span></button>
      {{/each}}
    </div>
  </section>

  <section class="panel">
    <h2>{{localize "ANIME5E.Labels.Combat"}}</h2>
    <div class="inline-fields">
      <label>
        Armour Class
        <input type="number" name="system.combat.armourClass" value="{{system.combat.baseArmourClass}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Hit Points
        <input type="number" name="system.combat.hitPoints.value" value="{{system.combat.hitPoints.value}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Deprivation
        <input type="number" name="system.combat.hitPoints.deprivationLoss" value="{{system.combat.hitPoints.deprivationLoss}}" min="0" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Temp HP
        <input type="number" name="system.combat.hitPoints.temporary" value="{{system.combat.hitPoints.temporary}}" min="0" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Max HP
        <input type="number" name="system.combat.hitPoints.max" value="{{system.combat.hitPoints.baseMax}}" min="0" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Hit Dice
        <input type="number" name="system.combat.hitDice.total" value="{{system.combat.hitDice.total}}" min="0" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Spent HD
        <input type="number" name="system.combat.hitDice.spent" value="{{system.combat.hitDice.spent}}" min="0" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Die Size
        <input type="number" name="system.combat.hitDice.dieSize" value="{{system.combat.hitDice.dieSize}}" min="0" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Energy
        <input type="number" name="system.combat.energy.value" value="{{system.combat.energy.value}}" min="0" {{#unless editable}}disabled{{/unless}}>
        <small class="derived-stat-note">{{energyMode.label}}</small>
      </label>
      <label>
        Max Energy
        <input type="number" name="system.combat.energy.max" value="{{system.combat.energy.baseMax}}" min="0" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Movement
        <input type="number" name="system.combat.movementSpeed" value="{{system.combat.baseMovementSpeed}}" min="0" {{#unless editable}}disabled{{/unless}}>
        {{#if combatEffects.movement}}<small class="derived-stat-note">{{combatEffects.movement}}</small>{{/if}}
      </label>
      <label>
        Fly
        <input type="text" name="system.combat.flightSpeed" value="{{system.combat.flightSpeed}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Water/Swim
        <input type="text" name="system.combat.waterSpeed" value="{{system.combat.waterSpeed}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Climb
        <input type="text" name="system.combat.climbSpeed" value="{{system.combat.climbSpeed}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Burrow
        <input type="text" name="system.combat.burrowSpeed" value="{{system.combat.burrowSpeed}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Proficiency
        <input type="number" name="system.combat.proficiencyBonus" value="{{system.combat.proficiencyBonus}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Initiative
        <input type="number" name="system.combat.initiative" value="{{system.combat.initiative}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <button type="button" class="roll-action" data-action="roll-initiative"><i class="fas fa-dice-d20"></i> Initiative</button>
    </div>
    <section class="energy-panel" aria-label="Energy Spending And Recovery">
      <h3>Energy Changes</h3>
      <p class="sheet-warning">{{energyMode.label}}</p>
      {{#if energyMode.enabled}}
        <div class="energy-controls">
          <label>
            Amount
            <input type="number" data-energy-input="amount" value="0" min="0">
          </label>
          <button type="button" class="roll-action" data-action="spend-energy"><i class="fas fa-bolt"></i> Spend</button>
          <button type="button" class="roll-action" data-action="restore-energy"><i class="fas fa-plus"></i> Restore</button>
        </div>
      {{/if}}
    </section>
    <section class="damage-profile-panel" aria-label="Damage Type Handling">
      <h3>Damage Type Handling</h3>
      <div class="damage-profile-controls">
        <label>
          Immunities
          <input type="text" name="system.combat.damageProfile.immunities" value="{{system.combat.damageProfile.immunities}}" placeholder="fire, poison" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Resistances
          <input type="text" name="system.combat.damageProfile.resistances" value="{{system.combat.damageProfile.resistances}}" placeholder="cold, slashing" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Vulnerabilities
          <input type="text" name="system.combat.damageProfile.vulnerabilities" value="{{system.combat.damageProfile.vulnerabilities}}" placeholder="psychic" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Reduction
          <input type="number" name="system.combat.damageProfile.reduction" value="{{system.combat.damageProfile.reduction}}" min="0" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label>
          Reduction Types
          <input type="text" name="system.combat.damageProfile.reductionTypes" value="{{system.combat.damageProfile.reductionTypes}}" placeholder="melee, ranged, standard" {{#unless editable}}disabled{{/unless}}>
        </label>
        <label class="wide">
          Notes
          <input type="text" name="system.combat.damageProfile.notes" value="{{system.combat.damageProfile.notes}}" {{#unless editable}}disabled{{/unless}}>
        </label>
      </div>
    </section>
    <section class="rest-recovery-panel" aria-label="Rest And Recovery">
      <h3>Rest & Recovery</h3>
      <p class="sheet-warning">{{restRecovery.woundPressure.status}}</p>
      <div class="rest-summary">
        <span>Available HD <strong>{{restRecovery.hitDice.available}} / {{restRecovery.hitDice.total}}</strong><small>{{restRecovery.hitDice.label}}</small></span>
        <span>Wound Threshold <strong>{{restRecovery.woundPressure.threshold}}</strong><small>{{restRecovery.woundPressure.current}} / {{restRecovery.woundPressure.max}} HP</small></span>
      </div>
      <div class="rest-controls">
        <label>
          Spend HD
          <input type="number" data-rest-input="hitDiceSpent" value="0" min="0" max="{{restRecovery.hitDice.available}}">
        </label>
        <button type="button" class="roll-action" data-action="short-rest-recovery"><i class="fas fa-hourglass-half"></i> Short Rest</button>
        <button type="button" class="roll-action" data-action="long-rest-recovery"><i class="fas fa-bed"></i> Long Rest</button>
      </div>
    </section>
  </section>

  <section class="panel combat-manoeuvre-panel">
    <h2>Combat Manoeuvres</h2>
    <div class="combat-manoeuvre-controls">
      <label>
        Manoeuvre
        <select data-manoeuvre-input="id">
          {{#each combatManoeuvres.groups as |group|}}
            <optgroup label="{{group.label}}">
              {{#each group.entries as |entry|}}
                <option value="{{entry.id}}">{{entry.label}} ({{entry.rollModeLabel}})</option>
              {{/each}}
            </optgroup>
          {{/each}}
        </select>
      </label>
      <label>
        Attack Row
        <select data-manoeuvre-input="attack">
          {{#each attackRows as |attackRow|}}
            <option value="{{attackRow.key}}">{{attackRow.label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        Target
        <input type="text" data-manoeuvre-input="target" value="{{combatActionState.target}}">
      </label>
      <button type="button" class="roll-action" data-action="roll-combat-manoeuvre"><i class="fas fa-dice-d20"></i> Roll</button>
      <button type="button" class="roll-action" data-action="post-combat-manoeuvre"><i class="fas fa-comment"></i> Post</button>
      <button type="button" class="roll-action" data-action="track-combat-manoeuvre"><i class="fas fa-thumbtack"></i> Track</button>
    </div>
    <div class="combat-action-state">
      <label>
        Tactical
        <input type="text" name="system.combat.actionState.tacticalAction" value="{{system.combat.actionState.tacticalAction}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label>
        Grapple
        <input type="text" name="system.combat.actionState.grappleState" value="{{system.combat.actionState.grappleState}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <label class="wide">
        Notes
        <input type="text" name="system.combat.actionState.notes" value="{{system.combat.actionState.notes}}" {{#unless editable}}disabled{{/unless}}>
      </label>
      <button type="button" class="roll-action" data-action="clear-combat-action-state"><i class="fas fa-eraser"></i> Clear</button>
    </div>
    <p class="sheet-warning">{{combatActionState.summary}}</p>
  </section>

  {{#if dynamicPowers.active}}
    <section class="panel dynamic-power-panel">
      <h2>Dynamic Power Expression</h2>
      <div class="dynamic-power-controls">
        <label>
          Power
          <select data-dynamic-power-input="itemId">
            {{#each dynamicPowers.entries as |power|}}
              <option value="{{power.id}}">{{power.name}} (Rank {{power.rank}})</option>
            {{/each}}
          </select>
        </label>
        <label>
          Ability
          <select data-dynamic-power-input="ability">
            {{#each abilities as |ability|}}
              <option value="{{ability.key}}">{{ability.label}}</option>
            {{/each}}
          </select>
        </label>
        <label>
          Effect Rank
          <input type="number" data-dynamic-power-input="effectRank" value="1" min="0">
        </label>
        <label>
          Energy
          <input type="number" data-dynamic-power-input="energyCost" value="0" min="0">
        </label>
        <label>
          Roll
          <select data-dynamic-power-input="d20Mode">
            {{#each d20Modes as |mode|}}
              <option value="{{mode.key}}">{{mode.label}}</option>
            {{/each}}
          </select>
        </label>
        <label>
          Bonus
          <input type="number" data-dynamic-power-input="bonus" value="0">
        </label>
        <label class="wide">
          Expression
          <input type="text" data-dynamic-power-input="expression">
        </label>
        <label class="wide">
          Notes
          <input type="text" data-dynamic-power-input="notes">
        </label>
        <div class="dynamic-power-actions">
          <button type="button" class="roll-action" data-action="roll-dynamic-power-check"><i class="fas fa-dice-d20"></i> Check</button>
          <button type="button" class="roll-action" data-action="express-dynamic-power"><i class="fas fa-wand-magic-sparkles"></i> Express</button>
        </div>
      </div>
    </section>
  {{/if}}

  <section class="panel">
    <h2>Common Attacks</h2>
    <div class="folio-table attack-table action-table">
      <div class="table-header">Weapon</div>
      <div class="table-header">Mod</div>
      <div class="table-header">Kind</div>
      <div class="table-header">Range</div>
      <div class="table-header">Roll</div>
      <div class="table-header">AC</div>
      <div class="table-header">Cover</div>
      <div class="table-header">Penalty</div>
      <div class="table-header">Dmg Type</div>
      <div class="table-header">Damage</div>
      <div class="table-header">Attack</div>
      <div class="table-header">Damage</div>
      {{#each attackRows as |attackRow|}}
        <input type="text" name="system.combat.attacks.{{attackRow.key}}.weapon" value="{{attackRow.data.weapon}}" {{#unless ../editable}}disabled{{/unless}}>
        <input type="text" name="system.combat.attacks.{{attackRow.key}}.modifier" value="{{attackRow.data.modifier}}" {{#unless ../editable}}disabled{{/unless}}>
        <input type="text" name="system.combat.attacks.{{attackRow.key}}.attackType" value="{{attackRow.data.attackType}}" {{#unless ../editable}}disabled{{/unless}}>
        <input type="text" name="system.combat.attacks.{{attackRow.key}}.range" value="{{attackRow.data.range}}" {{#unless ../editable}}disabled{{/unless}}>
        <select name="system.combat.attacks.{{attackRow.key}}.d20Mode" {{#unless ../editable}}disabled{{/unless}}>
          {{#each attackRow.d20Modes as |mode|}}
            <option value="{{mode.key}}" {{#if mode.selected}}selected{{/if}}>{{mode.label}}</option>
          {{/each}}
        </select>
        <input type="number" name="system.combat.attacks.{{attackRow.key}}.targetArmourClass" value="{{attackRow.data.targetArmourClass}}" min="0" {{#unless ../editable}}disabled{{/unless}}>
        <select name="system.combat.attacks.{{attackRow.key}}.cover" {{#unless ../editable}}disabled{{/unless}}>
          {{#each attackRow.coverOptions as |cover|}}
            <option value="{{cover.key}}" {{#if cover.selected}}selected{{/if}}>{{cover.label}}</option>
          {{/each}}
        </select>
        <input type="number" name="system.combat.attacks.{{attackRow.key}}.rangePenalty" value="{{attackRow.data.rangePenalty}}" min="0" {{#unless ../editable}}disabled{{/unless}}>
        <input type="text" name="system.combat.attacks.{{attackRow.key}}.damageType" value="{{attackRow.data.damageType}}" {{#unless ../editable}}disabled{{/unless}}>
        <input type="text" name="system.combat.attacks.{{attackRow.key}}.damage" value="{{attackRow.data.damage}}" {{#unless ../editable}}disabled{{/unless}}>
        <button type="button" class="icon-button" data-action="roll-attack" data-attack="{{attackRow.key}}" title="Roll attack"><i class="fas fa-dice-d20"></i></button>
        <button type="button" class="icon-button" data-action="roll-damage" data-attack="{{attackRow.key}}" title="Roll damage"><i class="fas fa-bolt"></i></button>
      {{/each}}
    </div>
  </section>

  <section class="panel item-drop-panel skill-roll-panel" data-drop-target="items">
    <h2>Owned Items</h2>
    <div class="skill-roll-controls">
      <label>
        Skill Roll
        <select data-roll-input="skillD20Mode">
          {{#each d20Modes as |mode|}}
            <option value="{{mode.key}}">{{mode.label}}</option>
          {{/each}}
        </select>
      </label>
      <label>
        Bonus
        <input type="number" data-roll-input="skillBonus" value="0">
      </label>
    </div>
    <ol class="item-list folio-item-list">
      {{#each itemGroups.all as |item|}}
        <li class="item-row" data-item-id="{{item.id}}">
          <img src="{{item.img}}" alt="{{item.name}}">
          <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
          <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
          <div class="item-actions">
            {{#if item.canUse}}<button type="button" data-action="use-item" title="Use"><i class="fas fa-comment"></i></button>{{/if}}
            {{#if item.canSkillCheck}}<button type="button" data-action="roll-skill-item" title="Skill Check"><i class="fas fa-dice-d20"></i></button>{{/if}}
            {{#if item.canRoll}}<button type="button" data-action="roll-item" title="Roll"><i class="fas fa-dice-d20"></i></button>{{/if}}
            {{#if item.canPowerCheck}}<button type="button" data-action="roll-power-check" title="Power Check"><i class="fas fa-wand-magic-sparkles"></i></button>{{/if}}
            {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
            {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
            {{#if ../editable}}{{#if item.equippable}}<button type="button" data-action="toggle-equipped" title="{{#if item.equipped}}Unequip{{else}}Equip{{/if}}"><i class="fas {{#if item.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i></button>{{/if}}{{/if}}
            {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
          </div>
        </li>
      {{else}}
        <li class="item-row empty"><span></span><span>No owned items.</span><small></small></li>
      {{/each}}
    </ol>
  </section>

  <section class="folio-grid two-column">
    <section class="notes-box"><h2>Notes</h2><textarea name="system.notes.overview" {{#unless editable}}disabled{{/unless}}>{{system.notes.overview}}</textarea></section>
    <section class="notes-box"><h2>Stat Block</h2><textarea name="system.statBlock" {{#unless editable}}disabled{{/unless}}>{{system.statBlock}}</textarea></section>
  </section>

  {{#if editable}}
    <footer class="sheet-footer">
      <div class="rules-reference-actions" aria-label="Core Rules References">
        {{#each rulesReferenceLinks as |link|}}
          <button type="button" class="icon-button" data-action="open-rules-reference" data-source-id="{{link.sourceId}}" title="{{link.label}} Reference"><i class="fas {{link.icon}}"></i></button>
        {{/each}}
      </div>
      <button type="submit">{{localize "ANIME5E.Labels.Save"}}</button>
    </footer>
  {{/if}}
</form>
