            {{else}}
              <li class="item-row empty"><span></span><span>Drop skills, proficiencies, tools, or languages here.</span><small></small></li>
            {{/each}}
          </ol>
        </section>
      </section>
      <section class="notes-box"><h2>Trained Capability Notes</h2><textarea name="system.notes.skills" {{#unless editable}}disabled{{/unless}}>{{system.notes.skills}}</textarea></section>
    </section>

    <section id="folio-tab-powers" class="tab folio-tab{{#if activeTabs.powers}} active{{/if}}" data-group="primary" data-tab="powers">
      <header class="folio-page-heading">
        <div>
          <span>Folio p. {{folioPages.powers.folioPages}} / PDF p. {{folioPages.powers.pdfPages}}</span>
          <h2>{{folioPages.powers.label}}</h2>
        </div>
        <p>{{folioPages.powers.summary}}</p>
      </header>

      <section class="ledger-section item-drop-panel" data-drop-target="items">
        <header class="ledger-heading">
          <h2>Magic, Psionics, Powers, Spells, Techniques</h2>
          {{#if editable}}
            <div class="ledger-actions">
              <button type="button" data-action="create-item" data-item-type="power" title="Create Power"><i class="fas fa-plus"></i><span>Power</span></button>
              <button type="button" data-action="create-item" data-item-type="spell" title="Create Spell"><i class="fas fa-plus"></i><span>Spell</span></button>
              <button type="button" data-action="create-item" data-item-type="technique" title="Create Technique"><i class="fas fa-plus"></i><span>Technique</span></button>
            </div>
          {{/if}}
        </header>
        <ol class="item-list folio-item-list">
          {{#each itemGroups.powers as |item|}}
            <li class="item-row" data-item-id="{{item.id}}">
              <img src="{{item.img}}" alt="{{item.name}}">
              <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
              <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
              <div class="item-actions">
                {{#if item.canUse}}<button type="button" data-action="use-item" title="Use"><i class="fas fa-comment"></i></button>{{/if}}
                {{#if item.canRoll}}<button type="button" data-action="roll-item" title="Roll"><i class="fas fa-dice-d20"></i></button>{{/if}}
                {{#if item.canPowerCheck}}<button type="button" data-action="roll-power-check" title="Power Check"><i class="fas fa-wand-magic-sparkles"></i></button>{{/if}}
                {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
                {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
                {{#if ../editable}}{{#if item.equippable}}<button type="button" data-action="toggle-equipped" title="{{#if item.equipped}}Unequip{{else}}Equip{{/if}}"><i class="fas {{#if item.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i></button>{{/if}}{{/if}}
                {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
              </div>
            </li>
          {{else}}
            <li class="item-row empty"><span></span><span>Drop powers, spells, psionics, or techniques here.</span><small></small></li>
          {{/each}}
        </ol>
      </section>
      <section class="notes-box"><h2>Energy Costs, Activation Rules, Prepared Or Known Powers</h2><textarea name="system.notes.powers" {{#unless editable}}disabled{{/unless}}>{{system.notes.powers}}</textarea></section>
    </section>

    <section id="folio-tab-inventory" class="tab folio-tab{{#if activeTabs.inventory}} active{{/if}}" data-group="primary" data-tab="inventory">
      <header class="folio-page-heading">
        <div>
          <span>Folio p. {{folioPages.inventory.folioPages}} / PDF p. {{folioPages.inventory.pdfPages}}</span>
          <h2>{{folioPages.inventory.label}}</h2>
        </div>
        <p>{{folioPages.inventory.summary}}</p>
      </header>

      <section class="paint-panel wallet-panel">
        <h2>Wallet</h2>
        <div class="wallet-grid">
          {{#each economy.currencyRows as |currency|}}
            <label>
              {{currency.label}}
              <input type="number" name="system.economy.currency.{{currency.key}}" value="{{currency.value}}" min="0" {{#unless ../editable}}disabled{{/unless}}>
            </label>
          {{/each}}
        </div>
        <label class="wallet-notes">
          Currency Notes
          <input type="text" name="system.economy.walletNotes" value="{{economy.walletNotes}}" {{#unless editable}}disabled{{/unless}}>
        </label>
      </section>

      <section class="ledger-section item-drop-panel" data-drop-target="items">
        <header class="ledger-heading">
          <h2>Gear, Items Of Power, Weapons, Armour, Money</h2>
          {{#if editable}}
            <div class="ledger-actions">
              <button type="button" data-action="create-item" data-item-type="equipment" title="Create Equipment"><i class="fas fa-plus"></i><span>Equipment</span></button>
              <button type="button" data-action="create-item" data-item-type="itemOfPower" title="Create Item of Power"><i class="fas fa-plus"></i><span>Item of Power</span></button>
              <button type="button" data-action="create-item" data-item-type="loot" title="Create Loot"><i class="fas fa-plus"></i><span>Loot</span></button>
            </div>
          {{/if}}
        </header>
        <ol class="item-list folio-item-list">
          {{#each itemGroups.inventory as |item|}}
            <li class="item-row" data-item-id="{{item.id}}">
              <img src="{{item.img}}" alt="{{item.name}}">
              <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
              <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
              <div class="item-actions">
                {{#if item.canUse}}<button type="button" data-action="use-item" title="Use"><i class="fas fa-comment"></i></button>{{/if}}
                {{#if item.canRoll}}<button type="button" data-action="roll-item" title="Roll"><i class="fas fa-dice-d20"></i></button>{{/if}}
                {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
                {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
                {{#if ../editable}}{{#if item.equippable}}<button type="button" data-action="toggle-equipped" title="{{#if item.equipped}}Unequip{{else}}Equip{{/if}}"><i class="fas {{#if item.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i></button>{{/if}}{{/if}}
                {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
              </div>
            </li>
          {{else}}
            <li class="item-row empty"><span></span><span>Drop inventory items here.</span><small></small></li>
          {{/each}}
        </ol>
      </section>
      <section class="ledger-section item-drop-panel crafting-project-panel" data-drop-target="items">
        <header class="ledger-heading">
          <h2>Crafting Projects</h2>
          {{#if editable}}
            <div class="ledger-actions">
              <button type="button" data-action="create-item" data-item-type="craftingProject" title="Create Crafting Project"><i class="fas fa-plus"></i><span>Project</span></button>
            </div>
          {{/if}}
        </header>
        <ol class="item-list folio-item-list">
          {{#each itemGroups.craftingProjects as |item|}}
            <li class="item-row" data-item-id="{{item.id}}">
              <img src="{{item.img}}" alt="{{item.name}}">
              <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
              <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
              <div class="item-actions">
                {{#if item.canUse}}<button type="button" data-action="use-item" title="Post Project Notes"><i class="fas fa-comment"></i></button>{{/if}}
                {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
              </div>
            </li>
          {{else}}
            <li class="item-row empty"><span></span><span>Track crafting projects, materials, costs, progress, and DC notes here.</span><small></small></li>
          {{/each}}
        </ol>
      </section>
      <section class="notes-box"><h2>Carried, Worn, Stored, Money, Item-Based Attributes</h2><textarea name="system.notes.inventory" {{#unless editable}}disabled{{/unless}}>{{system.notes.inventory}}</textarea></section>
    </section>

    <section id="folio-tab-companions" class="tab folio-tab{{#if activeTabs.companions}} active{{/if}}" data-group="primary" data-tab="companions">
      <header class="folio-page-heading">
        <div>
          <span>Folio p. {{folioPages.companions.folioPages}} / PDF p. {{folioPages.companions.pdfPages}}</span>
          <h2>{{folioPages.companions.label}}</h2>
        </div>
        <p>{{folioPages.companions.summary}}</p>
      </header>

      {{#if linkedActors.active}}
        <section class="ledger-section linked-actor-panel">
          <header class="ledger-heading">
            <h2>Linked Actors</h2>
          </header>
          <ol class="item-list folio-item-list">
            {{#each linkedActors.entries as |entry|}}
              <li class="item-row{{#if entry.missing}} missing-link{{/if}}" data-item-id="{{entry.itemId}}">
                <span></span>
                <div class="item-main"><strong>{{entry.actorName}}</strong><small>{{entry.itemName}}</small></div>
                <div class="item-tags">{{#each entry.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
                <div class="item-actions">
                  <button type="button" data-action="open-linked-actor" data-linked-uuid="{{entry.uuid}}" title="Open linked actor"><i class="fas fa-external-link-alt"></i></button>
                </div>
              </li>
            {{/each}}
          </ol>
        </section>
      {{/if}}

      <section class="ledger-section item-drop-panel" data-drop-target="items">
        <header class="ledger-heading">
          <h2>Vehicles, Mecha, Mounts, Companions</h2>
          {{#if editable}}
            <div class="ledger-actions">
              <button type="button" data-action="create-item" data-item-type="mount" title="Create Mount"><i class="fas fa-plus"></i><span>Mount</span></button>
              <button type="button" data-action="create-item" data-item-type="vehicle" title="Create Vehicle"><i class="fas fa-plus"></i><span>Vehicle</span></button>
              <button type="button" data-action="create-item" data-item-type="mecha" title="Create Mecha"><i class="fas fa-plus"></i><span>Mecha</span></button>
              <button type="button" data-action="create-item" data-item-type="monsterVariant" title="Create Monster Variant"><i class="fas fa-plus"></i><span>Variant</span></button>
            </div>
          {{/if}}
        </header>
        <ol class="item-list folio-item-list">
          {{#each itemGroups.companions as |item|}}
            <li class="item-row" data-item-id="{{item.id}}">
              <img src="{{item.img}}" alt="{{item.name}}">
              <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
              <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
              <div class="item-actions">
                {{#if item.canUse}}<button type="button" data-action="use-item" title="Use"><i class="fas fa-comment"></i></button>{{/if}}
                {{#if item.canRoll}}<button type="button" data-action="roll-item" title="Roll"><i class="fas fa-dice-d20"></i></button>{{/if}}
                {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
                {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
                {{#if ../editable}}{{#if item.canLinkActor}}<button type="button" data-action="create-linked-actor" title="{{item.linkActorTitle}}"><i class="fas {{item.linkActorIcon}}"></i></button>{{/if}}{{/if}}
                {{#if ../editable}}{{#if item.equippable}}<button type="button" data-action="toggle-equipped" title="{{#if item.equipped}}Unequip{{else}}Equip{{/if}}"><i class="fas {{#if item.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i></button>{{/if}}{{/if}}
                {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
              </div>
            </li>
          {{else}}
            <li class="item-row empty"><span></span><span>Drop vehicles, mecha, or owned equipment here.</span><small></small></li>
          {{/each}}
        </ol>
      </section>
      <section class="notes-box"><h2>Owned Creature And Equipment Summaries</h2><textarea name="system.notes.companions" {{#unless editable}}disabled{{/unless}}>{{system.notes.companions}}</textarea></section>
      <section class="notes-box"><h2>Linked Stat Summary</h2><textarea name="system.statBlock" {{#unless editable}}disabled{{/unless}}>{{system.statBlock}}</textarea></section>
    </section>

    <section id="folio-tab-biography" class="tab folio-tab{{#if activeTabs.biography}} active{{/if}}" data-group="primary" data-tab="biography">
      <header class="folio-page-heading">
        <div>
          <span>Folio p. {{folioPages.biography.folioPages}} / PDF p. {{folioPages.biography.pdfPages}}</span>
          <h2>{{folioPages.biography.label}}</h2>
        </div>
        <p>{{folioPages.biography.summary}}</p>
      </header>

      <section class="folio-grid two-column">
        <section class="notes-box"><h2>Appearance And Background</h2><textarea name="system.biography" {{#unless editable}}disabled{{/unless}}>{{system.biography}}</textarea></section>
        <section class="notes-box"><h2>Personality</h2><textarea name="system.notes.personality" {{#unless editable}}disabled{{/unless}}>{{system.notes.personality}}</textarea></section>
        <section class="notes-box"><h2>History</h2><textarea name="system.notes.history" {{#unless editable}}disabled{{/unless}}>{{system.notes.history}}</textarea></section>
        <section class="notes-box"><h2>Family, Allies, Enemies</h2><textarea name="system.notes.family" {{#unless editable}}disabled{{/unless}}>{{system.notes.family}}</textarea></section>
        <section class="notes-box"><h2>Goals And Secrets</h2><textarea name="system.notes.goals" {{#unless editable}}disabled{{/unless}}>{{system.notes.goals}}</textarea></section>
        <section class="notes-box"><h2>Character Group</h2><textarea name="system.notes.group" {{#unless editable}}disabled{{/unless}}>{{system.notes.group}}</textarea></section>
        <section class="notes-box"><h2>Other Biography Notes</h2><textarea name="system.notes.biography" {{#unless editable}}disabled{{/unless}}>{{system.notes.biography}}</textarea></section>
      </section>
      <section class="notes-box"><h2>Campaign Role</h2><textarea name="system.identity.actorRole" {{#unless editable}}disabled{{/unless}}>{{system.identity.actorRole}}</textarea></section>
    </section>

    <section id="folio-tab-journal" class="tab folio-tab{{#if activeTabs.journal}} active{{/if}}" data-group="primary" data-tab="journal">
      <header class="folio-page-heading">
        <div>
          <span>Folio p. {{folioPages.journal.folioPages}} / PDF p. {{folioPages.journal.pdfPages}}</span>
          <h2>{{folioPages.journal.label}}</h2>
        </div>
        <p>{{folioPages.journal.summary}}</p>
      </header>

      <section class="folio-grid two-column">
        <section class="paint-panel advancement-bookkeeping-panel">
          <h2>Advancement Bookkeeping</h2>
          <div class="advancement-grid">
            <label>
              Character Level
              <input type="number" value="{{advancement.levelProgress.currentLevel}}" readonly>
            </label>
            <label>
              Current XP
              <input type="number" value="{{advancement.levelProgress.currentExperience}}" readonly>
            </label>
            <label>
              XP To Next
              <input type="text" value="{{advancement.levelProgress.xpToNextLabel}}" readonly>
            </label>
            <label>
              Next Threshold
              <input type="text" value="{{advancement.levelProgress.nextThresholdLabel}}" readonly>
            </label>
            <label>
              Engagement Bonus Points
              <input type="number" name="system.identity.engagementBonusPoints" value="{{advancement.engagementBonusPoints}}" min="0" {{#unless editable}}disabled{{/unless}}>
            </label>
            <label>
              Other Non-Levelling Points
              <input type="number" name="system.identity.otherNonLevellingPoints" value="{{advancement.otherNonLevellingPoints}}" min="0" {{#unless editable}}disabled{{/unless}}>
            </label>
          </div>
          <div class="advancement-point-summary">
            {{#each advancement.pointRows as |row|}}
              <span>{{row.label}} <strong>{{row.value}}</strong></span>
            {{/each}}
          </div>
          {{#each advancement.warnings as |warning|}}
            <p class="sheet-warning">{{warning}}</p>
          {{/each}}
          <label class="advancement-notes">
            Advancement Notes
            <textarea name="system.notes.advancement" {{#unless editable}}disabled{{/unless}}>{{system.notes.advancement}}</textarea>
          </label>
        </section>
        <section class="ledger-section item-drop-panel adventuring-risk-panel" data-drop-target="items">
          <header class="ledger-heading">
            <h2>Adventuring Risks</h2>
            {{#if editable}}
              <div class="ledger-actions">
                <button type="button" data-action="create-item" data-item-type="adventuringRisk" title="Create Adventuring Risk"><i class="fas fa-plus"></i><span>Risk</span></button>
              </div>
            {{/if}}
          </header>
          <ol class="item-list folio-item-list">
            {{#each itemGroups.adventuringRisks as |item|}}
              <li class="item-row" data-item-id="{{item.id}}">
                <img src="{{item.img}}" alt="{{item.name}}">
                <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
                <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
                <div class="item-actions">
                  {{#if item.canUse}}<button type="button" data-action="use-item" title="Post Reminder"><i class="fas fa-comment"></i></button>{{/if}}
                  {{#if item.canApplyDeprivation}}<button type="button" data-action="apply-risk-deprivation" title="Apply Deprivation Loss"><i class="fas fa-hourglass-half"></i></button>{{/if}}
                  {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
                </div>
              </li>
            {{else}}
              <li class="item-row empty"><span></span><span>Track poison, disease, hazards, or deprivation here.</span><small></small></li>
            {{/each}}
          </ol>
        </section>
        <section class="notes-box journal-notes"><h2>Session Notes And Adventure Log</h2><textarea name="system.notes.journal" {{#unless editable}}disabled{{/unless}}>{{system.notes.journal}}</textarea></section>
        <section class="notes-box"><h2>Rewards, Downtime, Story Events</h2><textarea name="system.notes.overview" {{#unless editable}}disabled{{/unless}}>{{system.notes.overview}}</textarea></section>
      </section>
    </section>
  </section>

  <footer class="folio-footer">
    <strong>Anime 5e</strong>
    <span>Fifth Edition Fantasy Role-Playing Adventures</span>
    <div class="rules-reference-actions" aria-label="Core Rules References">
      {{#each rulesReferenceLinks as |link|}}
        <button type="button" class="icon-button" data-action="open-rules-reference" data-source-id="{{link.sourceId}}" title="{{link.label}} Reference"><i class="fas {{link.icon}}"></i></button>
      {{/each}}
    </div>
    {{#if editable}}
      <button type="submit">{{localize "ANIME5E.Labels.Save"}}</button>
    {{/if}}
  </footer>
</form>
