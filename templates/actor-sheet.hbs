<form class="anime5e-form folio-sheet tabbed-folio-sheet" autocomplete="off">
  <header class="folio-title">
    <span class="folio-page-number">A5E</span>
    <h1>Character Folio</h1>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary" aria-label="Character Folio Sections">
    {{#each tabs as |tab|}}
      <a class="item{{#if tab.active}} active{{/if}}" data-tab="{{tab.id}}" data-group="primary" aria-controls="folio-tab-{{tab.id}}" aria-selected="{{#if tab.active}}true{{else}}false{{/if}}">
        <span>{{tab.shortLabel}}</span>
        <small>Folio {{tab.folioPages}}</small>
      </a>
    {{/each}}
  </nav>

  <section class="sheet-body folio-tab-body">
    <section id="folio-tab-overview" class="tab folio-tab{{#if activeTabs.overview}} active{{/if}}" data-group="primary" data-tab="overview">
      <header class="folio-page-heading">
        <div>
          <span>Folio p. {{folioPages.overview.folioPages}} / PDF p. {{folioPages.overview.pdfPages}}</span>
          <h2>{{folioPages.overview.label}}</h2>
        </div>
        <p>{{folioPages.overview.summary}}</p>
      </header>

      <section class="ability-banner-grid" aria-label='{{localize "ANIME5E.Labels.Abilities"}}'>
        {{#each abilities as |ability|}}
          <article class="ability-banner">
            <label>
              <span>{{ability.label}}</span>
              <input type="number" name="system.abilities.{{ability.key}}.value" value="{{ability.data.value}}" {{#unless ../editable}}disabled{{/unless}}>
              {{#if ability.effectText}}<small class="derived-stat-note">{{ability.effectText}}</small>{{/if}}
            </label>
            <div class="modifier-block">
              <span>{{localize "ANIME5E.Labels.Modifier"}}</span>
              <strong>{{ability.data.modifier}}</strong>
              <button type="button" class="icon-button roll-button" data-action="roll-ability" data-ability="{{ability.key}}" data-label="{{ability.label}} Check" title="Roll {{ability.label}}">
                <i class="fas fa-dice-d20"></i>
              </button>
            </div>
          </article>
        {{/each}}
      </section>

      <section class="folio-stat-row">
        <label class="circle-stat">
          <span>Proficiency Bonus</span>
          <input type="number" name="system.combat.proficiencyBonus" value="{{system.combat.proficiencyBonus}}" {{#unless editable}}disabled{{/unless}}>
        </label>

        <div class="resource-stat torn-paper">
          <h2>Hit Points</h2>
          <label>
            Maximum
            <input type="number" name="system.combat.hitPoints.max" value="{{system.combat.hitPoints.baseMax}}" min="0" {{#unless editable}}disabled{{/unless}}>
            {{#if combatEffects.hitPoints}}<small class="derived-stat-note">{{combatEffects.hitPoints}}</small>{{/if}}
          </label>
          <label>
            Current
            <input type="number" name="system.combat.hitPoints.value" value="{{system.combat.hitPoints.value}}" min="0" {{#unless editable}}disabled{{/unless}}>
          </label>
          <label>
            Temporary
            <input type="number" name="system.combat.hitPoints.temporary" value="{{system.combat.hitPoints.temporary}}" min="0" {{#unless editable}}disabled{{/unless}}>
          </label>
        </div>

        <label class="shield-stat">
          <span>Armour Class</span>
          <input type="number" name="system.combat.armourClass" value="{{system.combat.baseArmourClass}}" {{#unless editable}}disabled{{/unless}}>
          {{#if combatEffects.armourClass}}<small class="derived-stat-note">{{combatEffects.armourClass}}</small>{{/if}}
        </label>

        <div class="resource-stat torn-paper">
          <h2>Energy Points</h2>
          <small class="derived-stat-note">{{energyMode.label}}</small>
          <label>
            Maximum
            <input type="number" name="system.combat.energy.max" value="{{system.combat.energy.baseMax}}" min="0" {{#unless editable}}disabled{{/unless}}>
            {{#if combatEffects.energy}}<small class="derived-stat-note">{{combatEffects.energy}}</small>{{/if}}
          </label>
          <label>
            Current
            <input type="number" name="system.combat.energy.value" value="{{system.combat.energy.value}}" min="0" {{#unless editable}}disabled{{/unless}}>
          </label>
        </div>

        <label class="circle-stat">
          <span>Movement Speed</span>
          <input type="number" name="system.combat.movementSpeed" value="{{system.combat.baseMovementSpeed}}" min="0" {{#unless editable}}disabled{{/unless}}>
          {{#if combatEffects.movement}}<small class="derived-stat-note">{{combatEffects.movement}}</small>{{/if}}
        </label>
      </section>

      {{#if attributeEffects.active}}
        <section class="attribute-effect-summary paint-panel">
          <h2>Active Attribute Effects</h2>
          {{#if attributeEffects.hasTotals}}
            <div class="attribute-effect-totals">
              {{#each attributeEffects.totals as |total|}}<span>{{total}}</span>{{/each}}
            </div>
          {{/if}}
          <ol class="attribute-effect-list">
            {{#each attributeEffects.effects as |effect|}}
              <li><strong>{{effect.label}}</strong><span>{{effect.detail}}</span><small>{{effect.source}}{{#if effect.usageLabel}} | {{effect.usageLabel}}{{/if}}</small></li>
            {{/each}}
          </ol>
          {{#if attributeEffects.hasUnapplied}}
            <ol class="attribute-effect-list unapplied-effect-list">
              {{#each attributeEffects.unapplied as |effect|}}
                <li><strong>{{effect.source}}</strong><span>{{effect.usage.statusLabel}}</span><small>{{effect.usage.label}}</small></li>
              {{/each}}
            </ol>
          {{/if}}
          {{#each attributeEffects.warnings as |warning|}}
            <p class="sheet-warning">{{warning}}</p>
          {{/each}}
        </section>
      {{/if}}

      <section class="folio-main-grid">
        <section class="folio-ruled-list">
          {{#each identityRows as |row|}}
            <label class="folio-line">
              <span>{{row.label}}:</span>
              <input type="{{#if row.type}}{{row.type}}{{else}}text{{/if}}" name="{{row.name}}" value="{{row.value}}" {{#unless ../editable}}disabled{{/unless}}>
            </label>
          {{/each}}
        </section>

        <section class="folio-side-stack">
          <section class="paint-panel level-panel">
            <header>
              <label>
                Character Level
                <input type="number" name="system.level" value="{{system.level}}" min="1" {{#unless editable}}disabled{{/unless}}>
              </label>
              <label>
                EXP
                <input type="number" name="system.experience" value="{{system.experience}}" min="0" {{#unless editable}}disabled{{/unless}}>
              </label>
            </header>
            <div class="folio-table compact-table">
              <div class="table-header">Class</div>
              <div class="table-header">Level</div>
              <div class="table-header">Hit Dice</div>
              {{#each classRows as |classRow|}}
                <input type="text" name="system.progression.classes.{{classRow.key}}.name" value="{{classRow.data.name}}" {{#unless ../editable}}disabled{{/unless}}>
                <input type="number" name="system.progression.classes.{{classRow.key}}.level" value="{{classRow.data.level}}" min="0" {{#unless ../editable}}disabled{{/unless}}>
                <input type="text" name="system.progression.classes.{{classRow.key}}.hitDice" value="{{classRow.data.hitDice}}" {{#unless ../editable}}disabled{{/unless}}>
              {{/each}}
            </div>
            <div class="level-progress-summary">
              <span>Current Level <strong>{{creation.levelProgress.currentLevel}}</strong></span>
              <span>Current XP <strong>{{creation.levelProgress.currentExperience}}</strong></span>
              <span>Next Level <strong>{{creation.levelProgress.nextLevelLabel}}</strong></span>
              <span>XP Needed <strong>{{creation.levelProgress.xpToNextLabel}}</strong></span>
              <span>Next Threshold <strong>{{creation.levelProgress.nextThresholdLabel}}</strong></span>
              <span>Progress <strong>{{creation.levelProgress.progressLabel}}</strong></span>
            </div>
            <div class="class-level-summary {{creation.classLevel.status}}">
              <span>Owned Class Levels <strong>{{creation.classLevel.classLevelTotal}}</strong></span>
              <span>Class Items <strong>{{creation.classLevel.classItemCount}}</strong></span>
              <span>Levelled Items <strong>{{creation.classLevel.classLevelItems}}</strong></span>
              <span>Actor Level <strong>{{creation.classLevel.actorLevel}}</strong></span>
              <span>Status <strong>{{creation.classLevel.statusLabel}}</strong></span>
            </div>
            {{#if creation.classLevel.hasClassLevels}}
              <ol class="class-level-list">
                {{#each creation.classLevel.classes as |classItem|}}
                  <li><span>{{classItem.name}}</span><strong>{{classItem.level}}</strong></li>
                {{/each}}
              </ol>
            {{/if}}
            {{#each creation.classLevel.warnings as |warning|}}
              <p class="sheet-warning">{{warning}}</p>
            {{/each}}
            {{#if creation.classBenefits.active}}
              <section class="class-benefit-panel">
                <h3>Class-Derived Benefits</h3>
                <div class="class-benefit-grid">
                  <span>Active Class <strong>{{creation.classBenefits.className}}</strong></span>
                  <span>Class Level <strong>{{creation.classBenefits.classLevel}}</strong></span>
                  <span>Hit Dice <strong>{{creation.classBenefits.hitDicePool}}</strong></span>
                  <span>Proficiency <strong>+{{creation.classBenefits.proficiencyBonus}}</strong></span>
                  <span>Saving Throws <strong>{{creation.classBenefits.savingThrows}}</strong></span>
                  <span>Bonus Points <strong>{{creation.classBenefits.bonusPoints}}</strong></span>
                </div>
                {{#if creation.classBenefits.proficiencies}}
                  <p>{{creation.classBenefits.proficiencies}}</p>
                {{/if}}
                <ol class="class-benefit-list">
                  {{#each creation.classBenefits.benefits as |benefit|}}
                    <li><span>Level {{benefit.level}}</span><strong>{{benefit.label}}</strong></li>
                  {{/each}}
                </ol>
              </section>
            {{/if}}
            {{#each creation.classBenefits.warnings as |warning|}}
              <p class="sheet-warning">{{warning}}</p>
            {{/each}}
          </section>

          <section class="paint-panel creation-panel">
            <h2>Creation Setup</h2>
            <div class="creation-grid">
              <label>
                Starting Level
                <input type="number" name="system.creation.startingLevel" value="{{creation.startingLevel}}" min="1" {{#unless editable}}disabled{{/unless}}>
              </label>
              <label>
                Starting XP
                <input type="number" name="system.creation.startingExperience" value="{{creation.startingExperience}}" min="0" {{#unless editable}}disabled{{/unless}}>
              </label>
              <label>
                Ability Points
                <input type="text" name="system.creation.abilityPointMode" value="{{creation.abilityPointMode}}" {{#unless editable}}disabled{{/unless}}>
              </label>
              <label>
                Source Budget
                <input type="number" value="{{creation.recommendedDiscretionaryPoints}}" readonly>
              </label>
              <label>
                XP Benchmark
                <input type="number" value="{{#if creation.hasRecommendedExperience}}{{creation.recommendedExperience}}{{else}}{{creation.startingExperience}}{{/if}}" readonly>
              </label>
              <label>
                Status
                <input type="text" value="{{creation.validationLabel}}" readonly>
              </label>
            </div>
            {{#if editable}}
              <div class="creation-actions">
                <button type="button" data-action="apply-creation-start"><i class="fas fa-level-up-alt"></i><span>Apply Start</span></button>
                <button type="button" data-action="apply-point-budget"><i class="fas fa-coins"></i><span>Set Budget</span></button>
              </div>
            {{/if}}
            <section class="benchmark-panel" aria-label="Character Benchmark Guidance">
              <header>
                <span>Benchmark</span>
                <strong>{{creation.benchmark.label}} ({{creation.benchmark.levelRange}})</strong>
              </header>
              <div class="benchmark-grid">
                <span>Ability Scores <strong>{{creation.benchmarkSummary.abilityScores}}</strong></span>
                <span>Attribute Rank <strong>{{creation.benchmarkSummary.attributeRank}}</strong></span>
                <span>Proficiency <strong>{{creation.benchmarkSummary.proficiencyBonus}}</strong></span>
                <span>Armour Class <strong>{{creation.benchmarkSummary.armourClass}}</strong></span>
                <span>Normal Damage <strong>{{creation.benchmarkSummary.normalDamage}}</strong></span>
              </div>
            </section>
            {{#if creation.validationNotes}}
              <pre class="creation-validation">{{creation.validationNotes}}</pre>
            {{/if}}
          </section>

          <section class="paint-panel point-summary-panel">
            <h2>Point Summary</h2>
            <div class="point-summary-grid">
              <label>
                Available
                <input type="number" value="{{pointSummary.available}}" readonly>
              </label>
              <label>
                Ability Scores
                <input type="number" value="{{pointSummary.abilityScoreCost}}" readonly>
              </label>
              <label>
                Species
                <input type="number" value="{{pointSummary.speciesCost}}" readonly>
              </label>
              <label>
                Classes
                <input type="number" value="{{pointSummary.classCost}}" readonly>
              </label>
              <label>
                Class Bonus
                <input type="number" value="{{pointSummary.classBonusPoints}}" readonly>
              </label>
              <label>
                Attributes
                <input type="number" value="{{pointSummary.attributeCost}}" readonly>
              </label>
              <label>
                Equipment
                <input type="number" value="{{pointSummary.equipmentCost}}" readonly>
              </label>
              <label>
                Other Spent
                <input type="number" name="system.points.spent" value="{{pointSummary.spent}}" min="0" {{#unless editable}}disabled{{/unless}}>
              </label>
              <label>
                Manual Refund
                <input type="number" name="system.points.refunded" value="{{pointSummary.refunded}}" min="0" {{#unless editable}}disabled{{/unless}}>
              </label>
              <label>
                Defect Refund
                <input type="number" value="{{pointSummary.defectRefund}}" readonly>
              </label>
              <label>
                Total Refund
                <input type="number" value="{{pointSummary.totalRefunded}}" readonly>
              </label>
              <label>
                Total Spent
                <input type="number" value="{{pointSummary.totalSpent}}" readonly>
              </label>
              <label>
                Remaining
                <input type="number" value="{{pointSummary.remaining}}" readonly>
              </label>
            </div>
            {{#each pointSummary.warnings as |warning|}}
              <p class="sheet-warning">{{warning}}</p>
            {{/each}}
            <label class="point-adjustment-notes">
              Manual Adjustment Notes
              <textarea name="system.points.adjustmentNotes" {{#unless editable}}disabled{{/unless}}>{{system.points.adjustmentNotes}}</textarea>
            </label>
          </section>

          <section class="notes-box compact-notes">
            <h2>Character Summary</h2>
            <textarea name="system.identity.description" {{#unless editable}}disabled{{/unless}}>{{system.identity.description}}</textarea>
          </section>
        </section>
      </section>

      {{#if speciesWorkflow.active}}
        <section class="paint-panel species-workflow-panel">
          <h2>Species Workflow</h2>
          <div class="species-workflow-summary">
            <span>Owned Species <strong>{{speciesWorkflow.count}}</strong></span>
            <span>Applied Species <strong>{{#if speciesWorkflow.hasApplied}}{{speciesWorkflow.appliedName}}{{else}}None{{/if}}</strong></span>
            <span>Species Points <strong>{{speciesWorkflow.totalCost}}</strong></span>
          </div>
          {{#each speciesWorkflow.warnings as |warning|}}
            <p class="sheet-warning">{{warning}}</p>
          {{/each}}
          <div class="species-workflow-paths">
            {{#each speciesWorkflow.specialPaths as |path|}}
              <span>
                <strong>{{path.label}}</strong>
                <em>{{path.status}}</em>
                <small>{{path.note}}</small>
              </span>
            {{/each}}
          </div>
          <ol class="species-workflow-list">
            {{#each speciesWorkflow.species as |species|}}
              <li class="{{#if species.isApplied}}applied{{/if}}" data-item-id="{{species.id}}">
                <img src="{{species.img}}" alt="{{species.name}}">
                <div class="species-main">
                  <strong>{{species.name}}</strong>
                  <small>{{species.pointCostLabel}}{{#if species.sourceLabel}} | {{species.sourceLabel}}{{/if}}</small>
                  {{#if species.summary}}<p>{{species.summary}}</p>{{/if}}
                </div>
                <div class="item-actions">
                  {{#if ../editable}}
                    {{#if species.isApplied}}
                      <button type="button" data-action="remove-species" title="Remove applied species"><i class="fas fa-times-circle"></i></button>
                    {{else}}
                      <button type="button" data-action="apply-species" title="Apply species"><i class="fas fa-check-circle"></i></button>
                    {{/if}}
                  {{/if}}
                  {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button>{{/if}}
                </div>
              </li>
            {{/each}}
          </ol>
        </section>
      {{/if}}

      {{#if sizeTemplateWorkflow.active}}
        <section class="paint-panel size-template-workflow-panel">
          <h2>Size Template Modifiers</h2>
          <div class="size-template-workflow-summary">
            <span>Owned Templates <strong>{{sizeTemplateWorkflow.count}}</strong></span>
            <span>Selected Template <strong>{{#if sizeTemplateWorkflow.hasApplied}}{{sizeTemplateWorkflow.appliedName}}{{else}}None{{/if}}</strong></span>
            <span>Template Points <strong>{{sizeTemplateWorkflow.totalCost}}</strong></span>
          </div>
          {{#if creation.sizeTemplateModifiers}}
            <div class="size-template-modifier-tags">
              {{#each creation.sizeTemplateModifiers as |modifier|}}<span>Applied: {{modifier}}</span>{{/each}}
            </div>
          {{/if}}
          {{#if sizeTemplateWorkflow.appliedModifierTags}}
            <div class="size-template-modifier-tags">
              {{#each sizeTemplateWorkflow.appliedModifierTags as |modifier|}}<span>{{modifier}}</span>{{/each}}
            </div>
          {{/if}}
          {{#each sizeTemplateWorkflow.warnings as |warning|}}
            <p class="sheet-warning">{{warning}}</p>
          {{/each}}
          <ol class="size-template-workflow-list">
            {{#each sizeTemplateWorkflow.templates as |template|}}
              <li class="{{#if template.isApplied}}applied{{/if}}" data-item-id="{{template.id}}">
                <img src="{{template.img}}" alt="{{template.name}}">
                <div class="size-template-main">
                  <strong>{{template.name}}</strong>
                  <small>{{template.pointCostLabel}}{{#if template.sourceLabel}} | {{template.sourceLabel}}{{/if}}</small>
                  {{#if template.modifierTags}}
                    <div class="size-template-modifier-tags">
                      {{#each template.modifierTags as |modifier|}}<span>{{modifier}}</span>{{/each}}
                    </div>
                  {{/if}}
                  {{#if template.summary}}<p>{{template.summary}}</p>{{/if}}
                </div>
                <div class="item-actions">
                  {{#if ../editable}}
                    {{#if template.isApplied}}
                      <button type="button" data-action="remove-size-template" title="Remove selected size template"><i class="fas fa-times-circle"></i></button>
                    {{else}}
                      <button type="button" data-action="apply-size-template" title="Apply size template"><i class="fas fa-check-circle"></i></button>
                    {{/if}}
                  {{/if}}
                  {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button>{{/if}}
                </div>
              </li>
            {{/each}}
          </ol>
        </section>
      {{/if}}

      <section class="ledger-section item-drop-panel" data-drop-target="items">
        <header class="ledger-heading">
          <h2>Character Options</h2>
          {{#if editable}}
            <div class="ledger-actions">
              <button type="button" data-action="create-item" data-item-type="species" title="Create Species"><i class="fas fa-plus"></i><span>Species</span></button>
              <button type="button" data-action="create-item" data-item-type="class" title="Create Class"><i class="fas fa-plus"></i><span>Class</span></button>
              <button type="button" data-action="create-item" data-item-type="background" title="Create Background"><i class="fas fa-plus"></i><span>Background</span></button>
            </div>
          {{/if}}
        </header>
        <ol class="item-list folio-item-list">
          {{#each itemGroups.characterOptions as |item|}}
            <li class="item-row" data-item-id="{{item.id}}">
              <img src="{{item.img}}" alt="{{item.name}}">
              <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
              <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
              <div class="item-actions">
                {{#if item.canUse}}<button type="button" data-action="use-item" title="Use"><i class="fas fa-comment"></i></button>{{/if}}
                {{#if ../editable}}{{#if item.canToggleEffect}}<button type="button" data-action="toggle-attribute-effect" title="{{item.effectToggleTitle}}"><i class="fas {{item.effectToggleIcon}}"></i></button>{{/if}}{{/if}}
                {{#if item.canRoll}}<button type="button" data-action="roll-item" title="Roll"><i class="fas fa-dice-d20"></i></button>{{/if}}
                {{#if item.canPowerCheck}}<button type="button" data-action="roll-power-check" title="Power Check"><i class="fas fa-wand-magic-sparkles"></i></button>{{/if}}
                {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
                {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
                {{#if ../editable}}{{#if item.equippable}}<button type="button" data-action="toggle-equipped" title="{{#if item.equipped}}Unequip{{else}}Equip{{/if}}"><i class="fas {{#if item.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i></button>{{/if}}{{/if}}
                {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
              </div>
            </li>
          {{else}}
            <li class="item-row empty"><span></span><span>No character option items.</span><small></small></li>
          {{/each}}
        </ol>
      </section>
    </section>

    <section id="folio-tab-combat" class="tab folio-tab{{#if activeTabs.combat}} active{{/if}}" data-group="primary" data-tab="combat">
      <header class="folio-page-heading">
        <div>
          <span>Folio p. {{folioPages.combat.folioPages}} / PDF p. {{folioPages.combat.pdfPages}}</span>
          <h2>{{folioPages.combat.label}}</h2>
        </div>
        <p>{{folioPages.combat.summary}}</p>
      </header>

      <section class="folio-grid two-column">
        <section class="paint-panel combat-panel">
          <h2>Common Attacks</h2>
          <div class="inline-fields">
            <label>
              Initiative
              <input type="number" name="system.combat.initiative" value="{{system.combat.initiative}}" {{#unless editable}}disabled{{/unless}}>
            </label>
            <label>
              Roll
              <select data-roll-input="initiativeD20Mode">
                {{#each d20Modes as |mode|}}
                  <option value="{{mode.key}}">{{mode.label}}</option>
                {{/each}}
              </select>
            </label>
            <button type="button" class="roll-action" data-action="roll-initiative"><i class="fas fa-dice-d20"></i> Initiative</button>
            <label>
              Saving Throws
              <input type="text" name="system.identity.savingThrows" value="{{system.identity.savingThrows}}" {{#unless editable}}disabled{{/unless}}>
            </label>
          </div>
          <section class="quick-roll-panel" aria-label="Quick Rolls">
            <h3>Quick Rolls</h3>
            <div class="quick-roll-controls">
              <label>
                Ability
                <select data-roll-input="ability">
                  {{#each abilities as |ability|}}
                    <option value="{{ability.key}}">{{ability.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                Mode
                <select data-roll-input="mode">
                  {{#each rollModes as |mode|}}
                    <option value="{{mode.key}}">{{mode.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                Roll
                <select data-roll-input="d20Mode">
                  {{#each d20Modes as |mode|}}
                    <option value="{{mode.key}}">{{mode.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                DC
                <input type="number" data-roll-input="dc" value="0" min="0">
              </label>
              <label>
                Bonus
                <input type="number" data-roll-input="bonus" value="0">
              </label>
              <button type="button" class="roll-action" data-action="roll-quick"><i class="fas fa-dice-d20"></i> Roll</button>
              <button type="button" class="roll-action" data-action="roll-contest"><i class="fas fa-user-friends"></i> Contest</button>
            </div>
          </section>
          <section class="movement-mode-panel" aria-label="Movement Modes">
            <h3>Movement Modes</h3>
            <div class="movement-mode-grid">
              <label>
                Ground
