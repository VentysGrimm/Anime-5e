<form class="anime5e-form folio-sheet tabbed-folio-sheet" autocomplete="off">
  <header class="folio-title">
    <span class="folio-page-number">A5E</span>
    <h1>Character Folio</h1>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary" aria-label="Character Folio Sections">
    {{#each tabs as |tab|}}
      <a class="item{{#if tab.active}} active{{/if}}" data-tab="{{tab.id}}" data-group="primary">{{tab.label}}</a>
    {{/each}}
  </nav>

  <section class="sheet-body folio-tab-body">
    <section class="tab folio-tab{{#if activeTabs.overview}} active{{/if}}" data-group="primary" data-tab="overview">
      <section class="ability-banner-grid" aria-label='{{localize "ANIME5E.Labels.Abilities"}}'>
        {{#each abilities as |ability|}}
          <article class="ability-banner">
            <label>
              <span>{{ability.label}}</span>
              <input type="number" name="system.abilities.{{ability.key}}.value" value="{{ability.data.value}}" {{#unless ../editable}}disabled{{/unless}}>
            </label>
            <div class="modifier-block">
              <span>{{localize "ANIME5E.Labels.Modifier"}}</span>
              <strong>{{ability.data.modifier}}</strong>
              <button type="button" class="icon-button roll-button" data-action="roll-ability" data-ability="{{ability.key}}" data-label="{{ability.label}} Check" title="Roll {{ability.label}}">
                <i class="fas fa-dice-d20"></i>
              </button>
            </div>
          </article>
        {{/each}}
      </section>

      <section class="folio-stat-row">
        <label class="circle-stat">
          <span>Proficiency Bonus</span>
          <input type="number" name="system.combat.proficiencyBonus" value="{{system.combat.proficiencyBonus}}" {{#unless editable}}disabled{{/unless}}>
        </label>

        <div class="resource-stat torn-paper">
          <h2>Hit Points</h2>
          <label>
            Maximum
            <input type="number" name="system.combat.hitPoints.max" value="{{system.combat.hitPoints.max}}" min="0" {{#unless editable}}disabled{{/unless}}>
          </label>
          <label>
            Current
            <input type="number" name="system.combat.hitPoints.value" value="{{system.combat.hitPoints.value}}" min="0" {{#unless editable}}disabled{{/unless}}>
          </label>
        </div>

        <label class="shield-stat">
          <span>Armour Class</span>
          <input type="number" name="system.combat.armourClass" value="{{system.combat.armourClass}}" {{#unless editable}}disabled{{/unless}}>
        </label>

        <div class="resource-stat torn-paper">
          <h2>Energy Points</h2>
          <label>
            Maximum
            <input type="number" name="system.combat.energy.max" value="{{system.combat.energy.max}}" min="0" {{#unless editable}}disabled{{/unless}}>
          </label>
          <label>
            Current
            <input type="number" name="system.combat.energy.value" value="{{system.combat.energy.value}}" min="0" {{#unless editable}}disabled{{/unless}}>
          </label>
        </div>

        <label class="circle-stat">
          <span>Movement Speed</span>
          <input type="number" name="system.combat.movementSpeed" value="{{system.combat.movementSpeed}}" min="0" {{#unless editable}}disabled{{/unless}}>
        </label>
      </section>

      <section class="folio-main-grid">
        <section class="folio-ruled-list">
          {{#each identityRows as |row|}}
            <label class="folio-line">
              <span>{{row.label}}:</span>
              <input type="{{#if row.type}}{{row.type}}{{else}}text{{/if}}" name="{{row.name}}" value="{{row.value}}" {{#unless ../editable}}disabled{{/unless}}>
            </label>
          {{/each}}
        </section>

        <section class="folio-side-stack">
          <section class="paint-panel level-panel">
            <header>
              <label>
                Character Level
                <input type="number" name="system.level" value="{{system.level}}" min="1" {{#unless editable}}disabled{{/unless}}>
              </label>
              <label>
                EXP
                <input type="number" name="system.experience" value="{{system.experience}}" min="0" {{#unless editable}}disabled{{/unless}}>
              </label>
            </header>
            <div class="folio-table compact-table">
              <div class="table-header">Class</div>
              <div class="table-header">Level</div>
              <div class="table-header">Hit Dice</div>
              {{#each classRows as |classRow|}}
                <input type="text" name="system.progression.classes.{{classRow.key}}.name" value="{{classRow.data.name}}" {{#unless ../editable}}disabled{{/unless}}>
                <input type="number" name="system.progression.classes.{{classRow.key}}.level" value="{{classRow.data.level}}" min="0" {{#unless ../editable}}disabled{{/unless}}>
                <input type="text" name="system.progression.classes.{{classRow.key}}.hitDice" value="{{classRow.data.hitDice}}" {{#unless ../editable}}disabled{{/unless}}>
              {{/each}}
            </div>
          </section>

          <section class="paint-panel point-summary-panel">
            <h2>Point Summary</h2>
            <div class="point-summary-grid">
              <label>
                Available
                <input type="number" value="{{pointSummary.available}}" readonly>
              </label>
              <label>
                Ability Scores
                <input type="number" value="{{pointSummary.abilityScoreCost}}" readonly>
              </label>
              <label>
                Species
                <input type="number" value="{{pointSummary.speciesCost}}" readonly>
              </label>
              <label>
                Classes
                <input type="number" value="{{pointSummary.classCost}}" readonly>
              </label>
              <label>
                Attributes
                <input type="number" value="{{pointSummary.attributeCost}}" readonly>
              </label>
              <label>
                Other Spent
                <input type="number" name="system.points.spent" value="{{pointSummary.spent}}" min="0" {{#unless editable}}disabled{{/unless}}>
              </label>
              <label>
                Manual Refund
                <input type="number" name="system.points.refunded" value="{{pointSummary.refunded}}" min="0" {{#unless editable}}disabled{{/unless}}>
              </label>
              <label>
                Defect Refund
                <input type="number" value="{{pointSummary.defectRefund}}" readonly>
              </label>
              <label>
                Total Refund
                <input type="number" value="{{pointSummary.totalRefunded}}" readonly>
              </label>
              <label>
                Total Spent
                <input type="number" value="{{pointSummary.totalSpent}}" readonly>
              </label>
              <label>
                Remaining
                <input type="number" value="{{pointSummary.remaining}}" readonly>
              </label>
            </div>
            {{#each pointSummary.warnings as |warning|}}
              <p class="sheet-warning">{{warning}}</p>
            {{/each}}
          </section>

          <section class="notes-box compact-notes">
            <h2>Character Summary</h2>
            <textarea name="system.identity.description" {{#unless editable}}disabled{{/unless}}>{{system.identity.description}}</textarea>
          </section>
        </section>
      </section>

      <section class="ledger-section item-drop-panel" data-drop-target="items">
        <header class="ledger-heading">
          <h2>Character Options</h2>
          {{#if editable}}
            <div class="ledger-actions">
              <button type="button" data-action="create-item" data-item-type="species" title="Create Species"><i class="fas fa-plus"></i><span>Species</span></button>
              <button type="button" data-action="create-item" data-item-type="class" title="Create Class"><i class="fas fa-plus"></i><span>Class</span></button>
              <button type="button" data-action="create-item" data-item-type="background" title="Create Background"><i class="fas fa-plus"></i><span>Background</span></button>
            </div>
          {{/if}}
        </header>
        <ol class="item-list folio-item-list">
          {{#each itemGroups.characterOptions as |item|}}
            <li class="item-row" data-item-id="{{item.id}}">
              <img src="{{item.img}}" alt="{{item.name}}">
              <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
              <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
              <div class="item-actions">
                {{#if item.canUse}}<button type="button" data-action="use-item" title="Use"><i class="fas fa-comment"></i></button>{{/if}}
                {{#if item.canRoll}}<button type="button" data-action="roll-item" title="Roll"><i class="fas fa-dice-d20"></i></button>{{/if}}
                {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
                {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
                {{#if ../editable}}{{#if item.equippable}}<button type="button" data-action="toggle-equipped" title="{{#if item.equipped}}Unequip{{else}}Equip{{/if}}"><i class="fas {{#if item.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i></button>{{/if}}{{/if}}
                {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
              </div>
            </li>
          {{else}}
            <li class="item-row empty"><span></span><span>No character option items.</span><small></small></li>
          {{/each}}
        </ol>
      </section>
    </section>

    <section class="tab folio-tab{{#if activeTabs.combat}} active{{/if}}" data-group="primary" data-tab="combat">
      <section class="folio-grid two-column">
        <section class="paint-panel combat-panel">
          <h2>Combat Core</h2>
          <div class="inline-fields">
            <label>
              Initiative
              <input type="number" name="system.combat.initiative" value="{{system.combat.initiative}}" {{#unless editable}}disabled{{/unless}}>
            </label>
            <button type="button" class="roll-action" data-action="roll-initiative"><i class="fas fa-dice-d20"></i> Initiative</button>
            <label>
              Saving Throws
              <input type="text" name="system.identity.savingThrows" value="{{system.identity.savingThrows}}" {{#unless editable}}disabled{{/unless}}>
            </label>
          </div>
          <section class="quick-roll-panel" aria-label="Quick Rolls">
            <h3>Quick Rolls</h3>
            <div class="quick-roll-controls">
              <label>
                Ability
                <select data-roll-input="ability">
                  {{#each abilities as |ability|}}
                    <option value="{{ability.key}}">{{ability.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                Mode
                <select data-roll-input="mode">
                  {{#each rollModes as |mode|}}
                    <option value="{{mode.key}}">{{mode.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                Roll
                <select data-roll-input="d20Mode">
                  {{#each d20Modes as |mode|}}
                    <option value="{{mode.key}}">{{mode.label}}</option>
                  {{/each}}
                </select>
              </label>
              <label>
                DC
                <input type="number" data-roll-input="dc" value="0" min="0">
              </label>
              <label>
                Bonus
                <input type="number" data-roll-input="bonus" value="0">
              </label>
              <button type="button" class="roll-action" data-action="roll-quick"><i class="fas fa-dice-d20"></i> Roll</button>
            </div>
          </section>
          <div class="folio-table attack-table action-table">
            <div class="table-header">Weapon</div>
            <div class="table-header">Modifier</div>
            <div class="table-header">Type</div>
            <div class="table-header">Damage</div>
            <div class="table-header">Attack</div>
            <div class="table-header">Damage</div>
            {{#each attackRows as |attackRow|}}
              <input type="text" name="system.combat.attacks.{{attackRow.key}}.weapon" value="{{attackRow.data.weapon}}" {{#unless ../editable}}disabled{{/unless}}>
              <input type="text" name="system.combat.attacks.{{attackRow.key}}.modifier" value="{{attackRow.data.modifier}}" {{#unless ../editable}}disabled{{/unless}}>
              <input type="text" name="system.combat.attacks.{{attackRow.key}}.damageType" value="{{attackRow.data.damageType}}" {{#unless ../editable}}disabled{{/unless}}>
              <input type="text" name="system.combat.attacks.{{attackRow.key}}.damage" value="{{attackRow.data.damage}}" {{#unless ../editable}}disabled{{/unless}}>
              <button type="button" class="icon-button" data-action="roll-attack" data-attack="{{attackRow.key}}" title="Roll attack"><i class="fas fa-dice-d20"></i></button>
              <button type="button" class="icon-button" data-action="roll-damage" data-attack="{{attackRow.key}}" title="Roll damage"><i class="fas fa-bolt"></i></button>
            {{/each}}
          </div>
          <section class="damage-panel" aria-label="Hit Point Damage And Healing">
            <h3>Hit Point Changes</h3>
            <div class="damage-controls">
              <label>
                Amount
                <input type="number" data-damage-input="amount" value="0" min="0">
              </label>
              <label>
                Type
                <input type="text" data-damage-input="type" placeholder="slashing">
              </label>
              <button type="button" class="roll-action" data-action="apply-damage"><i class="fas fa-heart-broken"></i> Damage</button>
              <button type="button" class="roll-action" data-action="apply-healing"><i class="fas fa-heart"></i> Heal</button>
            </div>
          </section>
          <section class="equipped-summary" aria-label="Equipped Combat Gear">
            <h3>Equipped Gear</h3>
            <div class="equipped-ac">
              <span>Effective AC</span>
              <strong>{{equipment.armourClass}}</strong>
              <small>{{equipment.armourDetails}}</small>
            </div>
            {{#if equipment.armourWarning}}
              <p class="sheet-warning">{{equipment.armourWarning}}</p>
            {{/if}}
            <ol class="item-list compact-equipped-list">
              {{#each equipment.weapons as |item|}}
                <li class="item-row" data-item-id="{{item.id}}">
                  <img src="{{item.img}}" alt="{{item.name}}">
                  <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
                  <div class="item-actions">
                    {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
                    {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
                    {{#if ../editable}}<button type="button" data-action="toggle-equipped" title="Unequip"><i class="fas fa-toggle-on"></i></button>{{/if}}
                  </div>
                </li>
              {{else}}
                <li class="item-row empty"><span></span><span>No equipped weapons.</span><small></small></li>
              {{/each}}
            </ol>
          </section>
        </section>

        <section class="ledger-section item-drop-panel" data-drop-target="items">
          <header class="ledger-heading">
            <h2>Combat Gear, Techniques, Defenses</h2>
            {{#if editable}}
              <div class="ledger-actions">
                <button type="button" data-action="create-item" data-item-type="weapon" title="Create Weapon"><i class="fas fa-plus"></i><span>Weapon</span></button>
                <button type="button" data-action="create-item" data-item-type="armor" title="Create Armour"><i class="fas fa-plus"></i><span>Armour</span></button>
                <button type="button" data-action="create-item" data-item-type="shield" title="Create Shield"><i class="fas fa-plus"></i><span>Shield</span></button>
                <button type="button" data-action="create-item" data-item-type="technique" title="Create Technique"><i class="fas fa-plus"></i><span>Technique</span></button>
              </div>
            {{/if}}
          </header>
          <ol class="item-list folio-item-list">
            {{#each itemGroups.combat as |item|}}
              <li class="item-row" data-item-id="{{item.id}}">
                <img src="{{item.img}}" alt="{{item.name}}">
                <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
                <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
                <div class="item-actions">
                  {{#if item.canUse}}<button type="button" data-action="use-item" title="Use"><i class="fas fa-comment"></i></button>{{/if}}
                  {{#if item.canRoll}}<button type="button" data-action="roll-item" title="Roll"><i class="fas fa-dice-d20"></i></button>{{/if}}
                  {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
                  {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
                  {{#if ../editable}}{{#if item.equippable}}<button type="button" data-action="toggle-equipped" title="{{#if item.equipped}}Unequip{{else}}Equip{{/if}}"><i class="fas {{#if item.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i></button>{{/if}}{{/if}}
                  {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
                </div>
              </li>
            {{else}}
              <li class="item-row empty"><span></span><span>Drop combat items here.</span><small></small></li>
            {{/each}}
          </ol>
        </section>
      </section>
      <section class="notes-box"><h2>Combat Notes, Defenses, Conditions</h2><textarea name="system.notes.combat" {{#unless editable}}disabled{{/unless}}>{{system.notes.combat}}</textarea></section>
    </section>

    <section class="tab folio-tab{{#if activeTabs.attributes}} active{{/if}}" data-group="primary" data-tab="attributes">
      <section class="ledger-section item-drop-panel" data-drop-target="items">
        <header class="ledger-heading">
          <h2>Anime 5E Attributes, Enhancements, Limiters</h2>
          {{#if editable}}
            <div class="ledger-actions">
              <button type="button" data-action="create-item" data-item-type="attribute" title="Create Attribute"><i class="fas fa-plus"></i><span>Attribute</span></button>
              <button type="button" data-action="create-item" data-item-type="enhancement" title="Create Enhancement"><i class="fas fa-plus"></i><span>Enhancement</span></button>
              <button type="button" data-action="create-item" data-item-type="limiter" title="Create Limiter"><i class="fas fa-plus"></i><span>Limiter</span></button>
            </div>
          {{/if}}
        </header>
        <ol class="item-list folio-item-list">
          {{#each itemGroups.attributes as |item|}}
            <li class="item-row" data-item-id="{{item.id}}">
              <img src="{{item.img}}" alt="{{item.name}}">
              <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
              <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
              <div class="item-actions">
                {{#if item.canUse}}<button type="button" data-action="use-item" title="Use"><i class="fas fa-comment"></i></button>{{/if}}
                {{#if item.canRoll}}<button type="button" data-action="roll-item" title="Roll"><i class="fas fa-dice-d20"></i></button>{{/if}}
                {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
                {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
                {{#if ../editable}}{{#if item.equippable}}<button type="button" data-action="toggle-equipped" title="{{#if item.equipped}}Unequip{{else}}Equip{{/if}}"><i class="fas {{#if item.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i></button>{{/if}}{{/if}}
                {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
              </div>
            </li>
          {{else}}
            <li class="item-row empty"><span></span><span>Drop Attributes, Enhancements, or Limiters here.</span><small></small></li>
          {{/each}}
        </ol>
      </section>
      <section class="notes-box"><h2>Activation, Range, Duration, Targets, Energy Costs</h2><textarea name="system.notes.attributes" {{#unless editable}}disabled{{/unless}}>{{system.notes.attributes}}</textarea></section>
    </section>

    <section class="tab folio-tab{{#if activeTabs.defects}} active{{/if}}" data-group="primary" data-tab="defects">
      <section class="ledger-section item-drop-panel" data-drop-target="items">
        <header class="ledger-heading">
          <h2>Defects</h2>
          {{#if editable}}
            <div class="ledger-actions">
              <button type="button" data-action="create-item" data-item-type="defect" title="Create Defect"><i class="fas fa-plus"></i><span>Defect</span></button>
            </div>
          {{/if}}
        </header>
        <ol class="item-list folio-item-list">
          {{#each itemGroups.defects as |item|}}
            <li class="item-row" data-item-id="{{item.id}}">
              <img src="{{item.img}}" alt="{{item.name}}">
              <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
              <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
              <div class="item-actions">
                {{#if item.canUse}}<button type="button" data-action="use-item" title="Use"><i class="fas fa-comment"></i></button>{{/if}}
                {{#if item.canRoll}}<button type="button" data-action="roll-item" title="Roll"><i class="fas fa-dice-d20"></i></button>{{/if}}
                {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
                {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
                {{#if ../editable}}{{#if item.equippable}}<button type="button" data-action="toggle-equipped" title="{{#if item.equipped}}Unequip{{else}}Equip{{/if}}"><i class="fas {{#if item.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i></button>{{/if}}{{/if}}
                {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
              </div>
            </li>
          {{else}}
            <li class="item-row empty"><span></span><span>Drop Defects here.</span><small></small></li>
          {{/each}}
        </ol>
      </section>
      <section class="notes-box"><h2>Mechanical Effects, Triggers, Limitations, Roleplaying Guidance</h2><textarea name="system.notes.defects" {{#unless editable}}disabled{{/unless}}>{{system.notes.defects}}</textarea></section>
    </section>

    <section class="tab folio-tab{{#if activeTabs.skills}} active{{/if}}" data-group="primary" data-tab="skills">
      <section class="folio-grid two-column">
        <section class="notes-box save-roll-panel">
          <h2>Saving Throws, Proficiencies, Languages, Movement, Senses</h2>
          <div class="save-roll-buttons">
            {{#each abilities as |ability|}}
              <button type="button" data-action="roll-saving-throw" data-ability="{{ability.key}}" title="Roll {{ability.label}} Saving Throw"><i class="fas fa-dice-d20"></i><span>{{ability.label}}</span></button>
            {{/each}}
          </div>
          <textarea name="system.identity.proficiencies" {{#unless editable}}disabled{{/unless}}>{{system.identity.proficiencies}}</textarea>
        </section>
        <section class="ledger-section item-drop-panel" data-drop-target="items">
          <header class="ledger-heading">
            <h2>Skills And Proficiencies</h2>
            {{#if editable}}
              <div class="ledger-actions">
                <button type="button" data-action="create-item" data-item-type="skill" title="Create Skill"><i class="fas fa-plus"></i><span>Skill</span></button>
                <button type="button" data-action="create-item" data-item-type="proficiency" title="Create Proficiency"><i class="fas fa-plus"></i><span>Proficiency</span></button>
                <button type="button" data-action="create-item" data-item-type="language" title="Create Language"><i class="fas fa-plus"></i><span>Language</span></button>
              </div>
            {{/if}}
          </header>
          <ol class="item-list folio-item-list">
            {{#each itemGroups.skills as |item|}}
              <li class="item-row" data-item-id="{{item.id}}">
                <img src="{{item.img}}" alt="{{item.name}}">
                <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
                <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
                <div class="item-actions">
                  {{#if item.canUse}}<button type="button" data-action="use-item" title="Use"><i class="fas fa-comment"></i></button>{{/if}}
                  {{#if item.canSkillCheck}}<button type="button" data-action="roll-skill-item" title="Skill Check"><i class="fas fa-dice-d20"></i></button>{{/if}}
                  {{#if item.canRoll}}<button type="button" data-action="roll-item" title="Roll"><i class="fas fa-dice-d20"></i></button>{{/if}}
                  {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
                  {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
                  {{#if ../editable}}{{#if item.equippable}}<button type="button" data-action="toggle-equipped" title="{{#if item.equipped}}Unequip{{else}}Equip{{/if}}"><i class="fas {{#if item.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i></button>{{/if}}{{/if}}
                  {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
                </div>
              </li>
            {{else}}
              <li class="item-row empty"><span></span><span>Drop skills, proficiencies, tools, or languages here.</span><small></small></li>
            {{/each}}
          </ol>
        </section>
      </section>
      <section class="notes-box"><h2>Trained Capability Notes</h2><textarea name="system.notes.skills" {{#unless editable}}disabled{{/unless}}>{{system.notes.skills}}</textarea></section>
    </section>

    <section class="tab folio-tab{{#if activeTabs.powers}} active{{/if}}" data-group="primary" data-tab="powers">
      <section class="ledger-section item-drop-panel" data-drop-target="items">
        <header class="ledger-heading">
          <h2>Dynamic Powers, Spell-Like Abilities, Spells, Techniques</h2>
          {{#if editable}}
            <div class="ledger-actions">
              <button type="button" data-action="create-item" data-item-type="power" title="Create Power"><i class="fas fa-plus"></i><span>Power</span></button>
              <button type="button" data-action="create-item" data-item-type="spell" title="Create Spell"><i class="fas fa-plus"></i><span>Spell</span></button>
              <button type="button" data-action="create-item" data-item-type="technique" title="Create Technique"><i class="fas fa-plus"></i><span>Technique</span></button>
            </div>
          {{/if}}
        </header>
        <ol class="item-list folio-item-list">
          {{#each itemGroups.powers as |item|}}
            <li class="item-row" data-item-id="{{item.id}}">
              <img src="{{item.img}}" alt="{{item.name}}">
              <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
              <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
              <div class="item-actions">
                {{#if item.canUse}}<button type="button" data-action="use-item" title="Use"><i class="fas fa-comment"></i></button>{{/if}}
                {{#if item.canRoll}}<button type="button" data-action="roll-item" title="Roll"><i class="fas fa-dice-d20"></i></button>{{/if}}
                {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
                {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
                {{#if ../editable}}{{#if item.equippable}}<button type="button" data-action="toggle-equipped" title="{{#if item.equipped}}Unequip{{else}}Equip{{/if}}"><i class="fas {{#if item.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i></button>{{/if}}{{/if}}
                {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
              </div>
            </li>
          {{else}}
            <li class="item-row empty"><span></span><span>Drop powers, spells, psionics, or techniques here.</span><small></small></li>
          {{/each}}
        </ol>
      </section>
      <section class="notes-box"><h2>Energy Costs, Activation Rules, Prepared Or Known Powers</h2><textarea name="system.notes.powers" {{#unless editable}}disabled{{/unless}}>{{system.notes.powers}}</textarea></section>
    </section>

    <section class="tab folio-tab{{#if activeTabs.inventory}} active{{/if}}" data-group="primary" data-tab="inventory">
      <section class="ledger-section item-drop-panel" data-drop-target="items">
        <header class="ledger-heading">
          <h2>Gear, Items Of Power, Weapons, Armour, Money</h2>
          {{#if editable}}
            <div class="ledger-actions">
              <button type="button" data-action="create-item" data-item-type="equipment" title="Create Equipment"><i class="fas fa-plus"></i><span>Equipment</span></button>
              <button type="button" data-action="create-item" data-item-type="itemOfPower" title="Create Item of Power"><i class="fas fa-plus"></i><span>Item of Power</span></button>
              <button type="button" data-action="create-item" data-item-type="loot" title="Create Loot"><i class="fas fa-plus"></i><span>Loot</span></button>
            </div>
          {{/if}}
        </header>
        <ol class="item-list folio-item-list">
          {{#each itemGroups.inventory as |item|}}
            <li class="item-row" data-item-id="{{item.id}}">
              <img src="{{item.img}}" alt="{{item.name}}">
              <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
              <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
              <div class="item-actions">
                {{#if item.canUse}}<button type="button" data-action="use-item" title="Use"><i class="fas fa-comment"></i></button>{{/if}}
                {{#if item.canRoll}}<button type="button" data-action="roll-item" title="Roll"><i class="fas fa-dice-d20"></i></button>{{/if}}
                {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
                {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
                {{#if ../editable}}{{#if item.equippable}}<button type="button" data-action="toggle-equipped" title="{{#if item.equipped}}Unequip{{else}}Equip{{/if}}"><i class="fas {{#if item.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i></button>{{/if}}{{/if}}
                {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
              </div>
            </li>
          {{else}}
            <li class="item-row empty"><span></span><span>Drop inventory items here.</span><small></small></li>
          {{/each}}
        </ol>
      </section>
      <section class="notes-box"><h2>Carried, Worn, Stored, Money, Item-Based Attributes</h2><textarea name="system.notes.inventory" {{#unless editable}}disabled{{/unless}}>{{system.notes.inventory}}</textarea></section>
    </section>

    <section class="tab folio-tab{{#if activeTabs.companions}} active{{/if}}" data-group="primary" data-tab="companions">
      <section class="ledger-section item-drop-panel" data-drop-target="items">
        <header class="ledger-heading">
          <h2>Companions, Vehicles, Mecha, Mounts</h2>
          {{#if editable}}
            <div class="ledger-actions">
              <button type="button" data-action="create-item" data-item-type="mount" title="Create Mount"><i class="fas fa-plus"></i><span>Mount</span></button>
              <button type="button" data-action="create-item" data-item-type="vehicle" title="Create Vehicle"><i class="fas fa-plus"></i><span>Vehicle</span></button>
              <button type="button" data-action="create-item" data-item-type="mecha" title="Create Mecha"><i class="fas fa-plus"></i><span>Mecha</span></button>
              <button type="button" data-action="create-item" data-item-type="monsterVariant" title="Create Monster Variant"><i class="fas fa-plus"></i><span>Variant</span></button>
            </div>
          {{/if}}
        </header>
        <ol class="item-list folio-item-list">
          {{#each itemGroups.companions as |item|}}
            <li class="item-row" data-item-id="{{item.id}}">
              <img src="{{item.img}}" alt="{{item.name}}">
              <div class="item-main"><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></div>
              <div class="item-tags">{{#each item.tags as |tag|}}<span>{{tag}}</span>{{/each}}</div>
              <div class="item-actions">
                {{#if item.canUse}}<button type="button" data-action="use-item" title="Use"><i class="fas fa-comment"></i></button>{{/if}}
                {{#if item.canRoll}}<button type="button" data-action="roll-item" title="Roll"><i class="fas fa-dice-d20"></i></button>{{/if}}
                {{#if item.canAttack}}<button type="button" data-action="roll-item-attack" title="Attack"><i class="fas fa-crosshairs"></i></button>{{/if}}
                {{#if item.canDamage}}<button type="button" data-action="roll-item-damage" title="Damage"><i class="fas fa-bolt"></i></button>{{/if}}
                {{#if ../editable}}{{#if item.equippable}}<button type="button" data-action="toggle-equipped" title="{{#if item.equipped}}Unequip{{else}}Equip{{/if}}"><i class="fas {{#if item.equipped}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i></button>{{/if}}{{/if}}
                {{#if ../editable}}<button type="button" data-action="edit-item" title="Edit"><i class="fas fa-edit"></i></button><button type="button" data-action="delete-item" title="Delete"><i class="fas fa-trash"></i></button>{{/if}}
              </div>
            </li>
          {{else}}
            <li class="item-row empty"><span></span><span>Drop vehicles, mecha, or owned equipment here.</span><small></small></li>
          {{/each}}
        </ol>
      </section>
      <section class="notes-box"><h2>Owned Creature And Equipment Summaries</h2><textarea name="system.notes.companions" {{#unless editable}}disabled{{/unless}}>{{system.notes.companions}}</textarea></section>
      <section class="notes-box"><h2>Linked Stat Summary</h2><textarea name="system.statBlock" {{#unless editable}}disabled{{/unless}}>{{system.statBlock}}</textarea></section>
    </section>

    <section class="tab folio-tab{{#if activeTabs.biography}} active{{/if}}" data-group="primary" data-tab="biography">
      <section class="folio-grid two-column">
        <section class="notes-box"><h2>Appearance, Personality, Background, History</h2><textarea name="system.biography" {{#unless editable}}disabled{{/unless}}>{{system.biography}}</textarea></section>
        <section class="notes-box"><h2>Family, Allies, Enemies, Homeland, Goals, Secrets</h2><textarea name="system.notes.biography" {{#unless editable}}disabled{{/unless}}>{{system.notes.biography}}</textarea></section>
      </section>
      <section class="notes-box"><h2>Campaign Role</h2><textarea name="system.identity.actorRole" {{#unless editable}}disabled{{/unless}}>{{system.identity.actorRole}}</textarea></section>
    </section>

    <section class="tab folio-tab{{#if activeTabs.journal}} active{{/if}}" data-group="primary" data-tab="journal">
      <section class="notes-box journal-notes"><h2>Session Notes, Adventure Log, Advancement, Rewards, Downtime</h2><textarea name="system.notes.journal" {{#unless editable}}disabled{{/unless}}>{{system.notes.journal}}</textarea></section>
      <section class="notes-box"><h2>Folio Notes</h2><textarea name="system.notes.overview" {{#unless editable}}disabled{{/unless}}>{{system.notes.overview}}</textarea></section>
    </section>
  </section>

  <footer class="folio-footer">
    <strong>Anime 5e</strong>
    <span>Fifth Edition Fantasy Role-Playing Adventures</span>
    {{#if editable}}
      <button type="submit">{{localize "ANIME5E.Labels.Save"}}</button>
    {{/if}}
  </footer>
</form>
